---
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: `${b}/servicios/`,      label: 'Servicios' },
  { href: `${b}/acreditaciones/`, label: 'Acreditaciones' },
  { href: `${b}/catalogo/`,       label: 'Catálogo' },
  { href: `${b}/nosotros/`,       label: 'Nosotros' },
];

const contactoLinks = [
  { href: `${b}/contacto/`,              label: 'Contacto general' },
  { href: `${b}/bolsa-de-trabajo/`,      label: 'Bolsa de trabajo' },
  { href: `${b}/quejas-y-sugerencias/`,  label: 'Quejas y sugerencias' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  const path = href.replace(b, '') || '/';
  if (path === '/') return currentPath === '/' || currentPath === `${b}/`;
  return currentPath.startsWith(href);
}

const contactoActive = contactoLinks.some(l => isActive(l.href));
---

<header class="site-header" role="banner">
  <div class="container">
    <a class="site-logo" href={`${b}/`} aria-label="IME Calibraciones — Inicio">
      <img src={`${b}/assets/images/logo/logo-principal.png`}
           alt="IME Calibraciones"
           width="160" height="48">
    </a>

    <button class="nav-toggle no-print" aria-label="Abrir menú" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <nav class="site-nav" role="navigation" aria-label="Navegación principal">
      {navLinks.map(link => (
        <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
          {link.label}
        </a>
      ))}

      <!-- Dropdown Contacto -->
      <div class={`nav-dropdown${contactoActive ? ' nav-dropdown--active' : ''}`}>
        <button class="nav-dropdown__trigger" aria-expanded="false" aria-haspopup="true">
          Contacto
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="14" height="14">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
          </svg>
        </button>
        <ul class="nav-dropdown__menu" role="menu">
          {contactoLinks.map(link => (
            <li role="none">
              <a href={link.href} role="menuitem" aria-current={isActive(link.href) ? 'page' : undefined}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <a href="https://calibracionesime.com.mx"
         target="_blank"
         rel="noopener noreferrer">
        Inicia sesión
      </a>

      <a href={`${b}/contacto/#contacto-form`} class="nav-cta">Cotizar</a>
    </nav>
  </div>
</header>

<script>
  document.querySelectorAll<HTMLElement>('.nav-dropdown__trigger').forEach(btn => {
    const dropdown = btn.closest('.nav-dropdown') as HTMLElement;
    const menu = btn.nextElementSibling as HTMLElement;
    let hideTimer: ReturnType<typeof setTimeout>;

    function show() {
      clearTimeout(hideTimer);
      const rect = btn.getBoundingClientRect();
      menu.style.left = `${rect.left + rect.width / 2}px`;
      menu.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    }

    function scheduleHide() {
      hideTimer = setTimeout(() => {
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      }, 120);
    }

    // Hover en trigger
    dropdown.addEventListener('mouseenter', show);
    dropdown.addEventListener('mouseleave', scheduleHide);

    // Hover en el propio menú (fixed, fuera del dropdown)
    menu.addEventListener('mouseenter', () => clearTimeout(hideTimer));
    menu.addEventListener('mouseleave', scheduleHide);

    // Click (móvil / teclado)
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.contains('is-open') ? scheduleHide() : show();
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll<HTMLElement>('.nav-dropdown__menu').forEach(m => {
      m.classList.remove('is-open');
    });
    document.querySelectorAll('.nav-dropdown__trigger').forEach(btn => {
      btn.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll<HTMLElement>('.nav-dropdown__menu').forEach(m => m.classList.remove('is-open'));
      document.querySelectorAll('.nav-dropdown__trigger').forEach(btn => btn.setAttribute('aria-expanded', 'false'));
    }
  });
</script>
