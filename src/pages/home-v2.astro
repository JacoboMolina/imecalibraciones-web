---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { clientes } from '../data/clientes';
import slide1 from '../assets/images/hero/slide-1.png';
import slide2 from '../assets/images/hero/slide-2.png';
import slide3 from '../assets/images/hero/slide-3.png';

const magnitudesGrupos = [
  { nombre: 'Dimensional y Geométrica', color: '#3b82f6', icon: 'M9 7.5l3 4.5m0 0l3-4.5M12 12v5.25M15 12H9m6 3H9m12-3a9 9 0 11-18 0 9 9 0 0118 0z', items: ['Longitud', 'Ángulo', 'Rugosidad', 'Velocidad', 'Aceleración', 'Par de apriete'] },
  { nombre: 'Masa y Fuerza',            color: '#8b5cf6', icon: 'M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.97zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.97z', items: ['Masa', 'Fuerza', 'Torque', 'Dureza'] },
  { nombre: 'Térmica y Ambiental',      color: '#ef4444', icon: 'M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z', items: ['Temperatura', 'Humedad', 'Densidad'] },
  { nombre: 'Presión y Flujo',          color: '#06b6d4', icon: 'M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15', items: ['Presión', 'Volumen', 'Flujo', 'Caudal', 'Viscosidad'] },
  { nombre: 'Eléctrica y Frecuencia',   color: '#f59e0b', icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z', items: ['Electricidad', 'Resistencia eléctrica', 'Tensión eléctrica', 'Corriente eléctrica', 'Potencia', 'Energía', 'Tiempo y Frecuencia'] },
  { nombre: 'Química',                  color: '#10b981', icon: 'M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15m-15.6 0A2.25 2.25 0 004.2 18h15.6a2.25 2.25 0 002.25-2.25V15m-18 0a2.25 2.25 0 01-.659-1.591l-1.341-7.5m20.659 9.091A2.25 2.25 0 0121.75 15m-18 0A2.25 2.25 0 002.25 15', items: ['pH', 'Concentración'] },
  { nombre: 'Acústica y Radiación',     color: '#ec4899', icon: 'M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z', items: ['Sonido', 'Vibración', 'Óptica', 'Radiación', 'Luminosidad'] },
];
---

<Base
  title="IME Calibraciones — Laboratorio Acreditado en Tlaxcala, México"
  description="Calibración acreditada de instrumentos de medición. Trazabilidad nacional e internacional. Servicio para industria manufacturera, farmacéutica y automotriz en México."
>
  <link rel="preload" as="video" href="/assets/video/hero-lab.mp4" type="video/mp4" slot="head">

  <main class="hv2">

    <!-- ══ 1. HERO ══ -->
    <section class="hv2-hero" id="hero" aria-label="Presentación IME Calibraciones">
      <div class="hv2-hero__bg" aria-hidden="true">
        <div class="hv2-hero__carousel" id="heroCarousel">
          <div class="hv2-hero__slide hv2-hero__slide--video hv2-hero__slide--active">
            <video autoplay muted loop playsinline poster="/assets/images/hero/hero-poster.png" fetchpriority="high">
              <source src="/assets/video/hero-lab.mp4" type="video/mp4">
            </video>
          </div>
          <div class="hv2-hero__slide">
            <Image src={slide1} alt="Laboratorio de calibración IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="eager" format="webp" quality={80} />
          </div>
          <div class="hv2-hero__slide">
            <Image src={slide2} alt="Instrumentos calibrados por IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="eager" format="webp" quality={80} />
          </div>
          <div class="hv2-hero__slide">
            <Image src={slide3} alt="Equipo de metrólogos IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="eager" format="webp" quality={80} />
          </div>
        </div>
        <div class="hv2-hero__overlay"></div>
      </div>

      <div class="hv2-hero__inner container">
        <div class="hv2-hero__trust-badges" aria-label="Acreditaciones">
          <span class="hv2-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/></svg>
            EMA · ISO/IEC 17025
          </span>
          <span class="hv2-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/></svg>
            PJLA No. 54194
          </span>
        </div>

        <h1 class="hv2-hero__title" id="hv2HeroTitle">
          Precisión que mueve<br>
          <em>a la industria mexicana</em>
        </h1>
        <p class="hv2-hero__sub" id="hv2HeroSub">
          Laboratorio de calibración con doble acreditación EMA y PJLA.<br>
          32 magnitudes · Tlaxcala para todo México y Guatemala.
        </p>
        <div class="hv2-hero__actions">
          <a href="/contacto/" class="btn btn-primary btn-lg">Solicitar cotización</a>
          <a href="/servicios/" class="btn btn-outline-white btn-lg">Ver servicios</a>
        </div>
      </div>

      <!-- Progress bars -->
      <div class="hero__progress-bars" aria-hidden="true">
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
      </div>

      <div class="hv2-hero__scroll" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" width="22" height="22">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </section>

    <!-- ══ 2. LOGOS — prueba social inmediata ══ -->
    <section class="hv2-logos" aria-label="Clientes de IME Calibraciones">
      <div class="container">
        <p class="hv2-logos__label">Empresas líderes que confían en IME</p>
        <div class="hv2-logos__nav" id="indNavMarquee" aria-label="Filtrar por industria">
          <div class="ind-nav__track" style="justify-content:center;flex-wrap:wrap;">
            <span class="ind-nav__item" style="opacity:.5;transition:opacity .6s ease,color .6s ease;">Automotriz</span>
            <span class="ind-nav__item" style="opacity:.5;transition:opacity .6s ease,color .6s ease;">Alimentaria</span>
            <span class="ind-nav__item" style="opacity:.5;transition:opacity .6s ease,color .6s ease;">Farmacéutica y Médica</span>
            <span class="ind-nav__item" style="opacity:.5;transition:opacity .6s ease,color .6s ease;">Energía</span>
            <span class="ind-nav__item" style="opacity:.5;transition:opacity .6s ease,color .6s ease;">Gobierno y Defensa</span>
          </div>
        </div>
        <div class="logos-marquee" id="logosMarquee">
          <div class="logos-marquee__track">
            <div class="logos-marquee__set">
              {clientes.map(logo => (
                <div class="logos-marquee__item" data-industry={logo.industry}>
                  <Image src={logo.src} alt={logo.alt} width={200} loading="lazy" format="webp" quality={85} />
                </div>
              ))}
            </div>
            <div class="logos-marquee__set" aria-hidden="true">
              {clientes.map(logo => (
                <div class="logos-marquee__item" data-industry={logo.industry}>
                  <Image src={logo.src} alt={logo.alt} width={200} loading="lazy" format="webp" quality={85} />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ 3. PROBLEMA / SOLUCIÓN ══ -->
    <section class="hv2-problema" aria-labelledby="problema-heading">
      <div class="container">
        <div class="hv2-problema__intro">
          <p class="hv2-problema__eyebrow">El problema que resolvemos</p>
          <h2 id="problema-heading" class="hv2-problema__title">
            Su auditoría exige trazabilidad.<br>Su certificado debe valer en cualquier país.
          </h2>
        </div>
        <div class="hv2-problema__filas">
          <div class="hv2-problema__fila animate-on-scroll">
            <div class="hv2-problema__problema">
              <span class="hv2-problema__x" aria-hidden="true">✕</span>
              <p>«Necesito certificados reconocidos en Estados Unidos y en toda Norteamérica»</p>
            </div>
            <div class="hv2-problema__flecha" aria-hidden="true">→</div>
            <div class="hv2-problema__solucion">
              <span class="hv2-problema__check" aria-hidden="true">✓</span>
              <p><strong>PJLA No. 54194</strong> — acreditación con reconocimiento internacional aceptada en todo el continente.</p>
            </div>
          </div>
          <div class="hv2-problema__fila animate-on-scroll">
            <div class="hv2-problema__problema">
              <span class="hv2-problema__x" aria-hidden="true">✕</span>
              <p>«Mi instrumento no puede calibrarse en México, lo envío al extranjero»</p>
            </div>
            <div class="hv2-problema__flecha" aria-hidden="true">→</div>
            <div class="hv2-problema__solucion">
              <span class="hv2-problema__check" aria-hidden="true">✓</span>
              <p><strong>Métodos patentados por IME</strong> — calibramos lo que antes obligaba envíos fuera del país.</p>
            </div>
          </div>
          <div class="hv2-problema__fila animate-on-scroll">
            <div class="hv2-problema__problema">
              <span class="hv2-problema__x" aria-hidden="true">✕</span>
              <p>«Tengo múltiples proveedores, cada uno cubre pocas magnitudes»</p>
            </div>
            <div class="hv2-problema__flecha" aria-hidden="true">→</div>
            <div class="hv2-problema__solucion">
              <span class="hv2-problema__check" aria-hidden="true">✓</span>
              <p><strong>32 magnitudes acreditadas</strong> en un solo laboratorio — con capacidad para 24,000 equipos al año.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ 4. NÚMEROS IMPACTO ══ -->
    <section class="hv2-numeros" aria-labelledby="numeros-heading">
      <h2 id="numeros-heading" class="sr-only">Indicadores de IME Calibraciones</h2>
      <div class="container">
        <div class="hv2-numeros__grid">
          <div class="hv2-numeros__item animate-on-scroll">
            <span class="hv2-numeros__num"><span class="counter" data-target="32" data-suffix="+">32+</span></span>
            <span class="hv2-numeros__label-top">Años de experiencia</span>
            <span class="hv2-numeros__label-sub">calibrando la industria mexicana</span>
          </div>
          <div class="hv2-numeros__item animate-on-scroll">
            <span class="hv2-numeros__num"><span class="counter" data-target="32">32</span></span>
            <span class="hv2-numeros__label-top">Magnitudes acreditadas</span>
            <span class="hv2-numeros__label-sub">ante PJLA · ISO/IEC 17025</span>
          </div>
          <div class="hv2-numeros__item animate-on-scroll">
            <span class="hv2-numeros__num"><span class="counter" data-target="24000" data-suffix="+">24,000+</span></span>
            <span class="hv2-numeros__label-top">Equipos calibrados</span>
            <span class="hv2-numeros__label-sub">al año en todas las magnitudes</span>
          </div>
          <div class="hv2-numeros__item animate-on-scroll">
            <span class="hv2-numeros__num"><span class="counter" data-target="39">39</span></span>
            <span class="hv2-numeros__label-top">Magnitudes totales</span>
            <span class="hv2-numeros__label-sub">32 ante PJLA · 7 ante EMA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ 5. SERVICIOS ══ -->
    <section class="section hv2-servicios" aria-labelledby="servicios-heading">
      <div class="container">
        <header class="section__header text-center">
          <p class="section__eyebrow">Servicios</p>
          <h2 class="section-title" id="servicios-heading">Calibramos lo que su proceso necesita</h2>
          <p class="section__subtitle text-muted">Servicio en laboratorio y en campo, en toda la República Mexicana y Guatemala.</p>
        </header>
        <div class="hv2-servicios__grid">

          <article class="hv2-servicio-card animate-on-scroll">
            <div class="hv2-servicio-card__icon" style="--sc:#08529a;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15m-15.6 0A2.25 2.25 0 004.2 18h15.6a2.25 2.25 0 002.25-2.25V15m-18 0a2.25 2.25 0 01-.659-1.591l-1.341-7.5m20.659 9.091A2.25 2.25 0 0121.75 15m-18 0A2.25 2.25 0 012.25 15"/></svg>
            </div>
            <h3>Calibración en Laboratorio</h3>
            <p>Recibimos sus instrumentos en nuestras instalaciones acreditadas en Tlaxcala. Recolección y entrega sin costo dentro de 100 km.</p>
            <a href="/servicios/" class="hv2-servicio-card__link">Ver servicio →</a>
          </article>

          <article class="hv2-servicio-card animate-on-scroll">
            <div class="hv2-servicio-card__icon" style="--sc:#3b82f6;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
            </div>
            <h3>Calibración On-Site</h3>
            <p>Nuestros ingenieros se desplazan a su planta con equipo patrón certificado. Sin mover sus instrumentos críticos ni detener su producción.</p>
            <a href="/servicios/" class="hv2-servicio-card__link">Ver servicio →</a>
          </article>

          <article class="hv2-servicio-card animate-on-scroll">
            <div class="hv2-servicio-card__icon" style="--sc:#10b981;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/></svg>
            </div>
            <h3>Mantenimiento Preventivo</h3>
            <p>Programas de mantenimiento y calibración que extienden la vida útil de sus equipos y garantizan lecturas confiables en todo momento.</p>
            <a href="/servicios/" class="hv2-servicio-card__link">Ver servicio →</a>
          </article>

          <article class="hv2-servicio-card animate-on-scroll">
            <div class="hv2-servicio-card__icon" style="--sc:#f59e0b;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/></svg>
            </div>
            <h3>Venta de Equipos</h3>
            <p>Amplia gama de equipos de medición industrial de las mejores marcas. Asesoría especializada para elegir el instrumento correcto.</p>
            <a href="/catalogo/" class="hv2-servicio-card__link">Ver catálogo →</a>
          </article>

        </div>
      </div>
    </section>

    <!-- ══ 6. 3 DIFERENCIADORES CLAVE ══ -->
    <section class="section hv2-diferenciadores" aria-labelledby="dif-heading">
      <div class="container">
        <header class="section__header text-center">
          <p class="section__eyebrow">¿Por qué IME?</p>
          <h2 class="section-title" id="dif-heading">Lo que ningún otro laboratorio puede ofrecerle</h2>
        </header>
        <div class="hv2-dif__grid">

          <div class="hv2-dif__card animate-on-scroll">
            <div class="hv2-dif__num" aria-hidden="true">01</div>
            <div class="hv2-dif__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/></svg>
            </div>
            <h3>Doble acreditación — único en México</h3>
