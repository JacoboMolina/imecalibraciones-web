  top: -4px; right: 16px;
  font-size: 80px; font-weight: 800;
  color: rgba(8,82,154,.055);
  line-height: 1;
  letter-spacing: -3px;
  pointer-events: none;
  user-select: none;
}
.hv2-dif__icon {
  width: 52px; height: 52px;
  background: color-mix(in srgb, var(--color-primary) 11%, white);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.hv2-dif__icon svg { width: 26px; height: 26px; color: var(--color-primary); }
.hv2-dif__card h3 { font-size: 1.0625rem; font-weight: 700; color: var(--color-ink); line-height: 1.3; }
.hv2-dif__card p  { font-size: .875rem; color: var(--color-muted); line-height: 1.75; }

/* ── MAGNITUDES ── */
.hv2-mag__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
@media (max-width: 1000px) { .hv2-mag__grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 640px)  { .hv2-mag__grid { grid-template-columns: repeat(2, 1fr); } }
.hv2-mag__card {
  border: 1px solid var(--color-line);
  border-radius: 14px;
  overflow: hidden;
  transition: box-shadow .25s ease, transform .25s ease;
}
.hv2-mag__card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,.08);
  transform: translateY(-2px);
}
.hv2-mag__card-head {
  background: color-mix(in srgb, var(--mg-color) 9%, white);
  padding: 16px 18px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid color-mix(in srgb, var(--mg-color) 15%, transparent);
}
.hv2-mag__card-head svg {
  width: 20px; height: 20px; flex-shrink: 0;
  color: var(--mg-color);
}
.hv2-mag__card-head h3 {
  font-size: .8rem; font-weight: 700;
  color: color-mix(in srgb, var(--mg-color) 80%, #111);
  line-height: 1.2;
}
.hv2-mag__items {
  list-style: none;
  padding: 14px 18px;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.hv2-mag__items li {
  font-size: .78rem;
  color: var(--color-muted);
  padding-left: 12px;
  position: relative;
  line-height: 1.4;
}
.hv2-mag__items li::before {
  content: '';
  position: absolute;
  left: 0; top: 6px;
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--mg-color);
  opacity: .6;
}
.hv2-mag__nota {
  text-align: center;
  font-size: .8125rem;
  color: var(--color-muted);
  margin-top: 28px;
  padding: 14px 20px;
  background: color-mix(in srgb, var(--color-primary) 5%, white);
  border: 1px solid color-mix(in srgb, var(--color-primary) 15%, transparent);
  border-radius: 10px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* ── CTA BAND ── */
.hv2-cta-band {
  background: linear-gradient(135deg, #041a39 0%, #08529a 100%);
  padding: 64px 0;
}
.hv2-cta-band__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
}
.hv2-cta-band__text h2 {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 700;
  color: #fff;
  margin-bottom: 6px;
}
.hv2-cta-band__text p {
  font-size: .875rem;
  color: rgba(255,255,255,.6);
  font-weight: 600;
  letter-spacing: .04em;
}
.hv2-cta-band__actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
@media (max-width: 640px) {
  .hv2-cta-band__inner { flex-direction: column; text-align: center; }
  .hv2-cta-band__actions { justify-content: center; }
}
</style>

<script>
  // ── Hero carousel con progress bars ──
  (function() {
    const carousel = document.querySelector('.hv2-hero__carousel');
    if (!carousel) return;
    const slides = carousel.querySelectorAll('.hv2-hero__slide');
    if (slides.length < 2) return;
    const bars = Array.from(document.querySelectorAll('.hero__progress-bar'));
    const titleEl = document.getElementById('hv2HeroTitle');
    const subEl   = document.getElementById('hv2HeroSub');
    const INTERVAL = 6000;
    let current = 0, timer;

    const SLIDES_DATA = [
      { title: 'Precisión que mueve<br><em>a la industria mexicana</em>',        sub: 'Laboratorio de calibración con doble acreditación EMA y PJLA.<br>32 magnitudes · Tlaxcala para todo México y Guatemala.' },
      { title: 'Ingeniería y Metrología<br><em>Certificada</em>',                sub: 'Servicio de Mantenimiento Preventivo y Calibración para mantener sus equipos en óptimas condiciones.' },
      { title: 'Venta de Equipos<br><em>de Medición Industrial</em>',            sub: 'Amplia gama de equipos de las mejores marcas. Asesoría especializada para cada industria.' },
      { title: 'Cobertura Nacional<br><em>e Internacional</em>', sub: 'Presencia en toda la República Mexicana y Guatemala · 32+ años calibrando la industria.' },
    ];

    function updateText(i) {
      const d = SLIDES_DATA[i % SLIDES_DATA.length];
      if (titleEl) { titleEl.style.opacity='0'; setTimeout(()=>{ titleEl.innerHTML=d.title; titleEl.style.opacity='1'; },180); }
      if (subEl)   { subEl.style.opacity='0';   setTimeout(()=>{ subEl.innerHTML=d.sub;     subEl.style.opacity='1'; },240); }
    }

    function updateBars(i) {
      bars.forEach((bar, idx) => {
        const fill = bar.querySelector('.hero__progress-fill');
        bar.classList.remove('hero__progress-bar--active','hero__progress-bar--done');
        if (fill) fill.style.animation = 'none';
        if (idx < i) {
          bar.classList.add('hero__progress-bar--done');
          if (fill) fill.style.width = '100%';
        } else if (idx === i) {
          bar.classList.add('hero__progress-bar--active');
          if (fill) { fill.style.width='0%'; void fill.offsetWidth; fill.style.animation=`hero-progress ${INTERVAL}ms linear forwards`; }
        } else if (fill) { fill.style.width='0%'; }
      });
    }
    function goTo(idx) {
      const video = slides[current].querySelector('video');
      if (video) video.pause();
      slides[current].classList.remove('hv2-hero__slide--active');
      current = (idx + slides.length) % slides.length;
      slides[current].classList.add('hv2-hero__slide--active');
      const v2 = slides[current].querySelector('video');
      if (v2) v2.play().catch(()=>{});
      updateBars(current);
      updateText(current);
    }
    function reset() { clearInterval(timer); timer = setInterval(() => goTo(current+1), INTERVAL); }
    // swipe
    let tx = 0;
    const heroEl = document.querySelector('.hv2-hero');
    if (heroEl) {
      heroEl.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, {passive:true});
      heroEl.addEventListener('touchend', e => { const dx = e.changedTouches[0].clientX - tx; if (Math.abs(dx)>50){goTo(dx<0?current+1:current-1);reset();} }, {passive:true});
    }
    updateBars(0);
    reset();
  })();

  // ── Video facade ──
  (function() {
    const facade = document.getElementById('videoFacade');
    if (!facade) return;
    function play() {
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${facade.dataset.videoId}?autoplay=1&rel=0`;
      iframe.title = 'Video institucional IME'; iframe.allowFullscreen = true;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      facade.innerHTML = ''; facade.appendChild(iframe); facade.style.cursor='default';
    }
    facade.addEventListener('click', play, {once:true});
    facade.addEventListener('keydown', e => { if(e.key==='Enter'||e.key===' '){e.preventDefault();play();} }, {once:true});
  })();

  // ── Logos marquee ──
  (function() {
    const marquee = document.getElementById('logosMarquee');
    const nav = document.getElementById('indNavMarquee');
    if (!marquee) return;
    const track = marquee.querySelector('.logos-marquee__track');
    const origSet = marquee.querySelector('.logos-marquee__set');
    if (!track || !origSet) return;
    track.style.animation = 'none';
    let pos=0, paused=false, currentInd=null, autoNavFn=null;
    let itemData=[], setWidth=0, halfW=0;
    function rebuild() {
      itemData=[]; setWidth=origSet.offsetWidth; halfW=marquee.offsetWidth/2;
      origSet.querySelectorAll('.logos-marquee__item').forEach(item => {
        if(item.style.display==='none') return;
        itemData.push({left:item.offsetLeft,right:item.offsetLeft+item.offsetWidth,industry:item.dataset.industry});
      });
    }
    requestAnimationFrame(rebuild);
    function tick() {
      if(!paused){
        pos+=1.3; if(pos>=setWidth&&setWidth) pos-=setWidth;
        track.style.transform=`translateX(-${pos}px)`;
        if(setWidth){ const c=(pos+halfW+200)%setWidth; for(const d of itemData){if(c>=d.left&&c<d.right){if(d.industry!==currentInd){currentInd=d.industry;autoNavFn?.(d.industry);} break;}} }
      }
      requestAnimationFrame(tick);
    }
    marquee.addEventListener('mouseenter',()=>{paused=true;});
    marquee.addEventListener('mouseleave',()=>{paused=false;});
    requestAnimationFrame(tick);
    function swapFilter(fn){ marquee.style.transition='opacity .22s ease'; marquee.style.opacity='0'; setTimeout(()=>{fn();pos=0;rebuild();marquee.style.opacity='1';},230); }
    const ctrl = {
      goToIndustry(name){const d=itemData.find(x=>x.industry===name);if(d)pos=d.left;},
      filterToIndustry(name){swapFilter(()=>track.querySelectorAll('.logos-marquee__item').forEach(i=>{i.style.display=i.dataset.industry===name?'':'none';}));},
      clearFilter(){swapFilter(()=>track.querySelectorAll('.logos-marquee__item').forEach(i=>{i.style.display='';}));}
    };
    if(nav){
      const navItems = Array.from(nav.querySelectorAll('.ind-nav__item'));
      let filterActive=false;
      autoNavFn = ind => {
        if(filterActive) return;
        navItems.forEach(i=>i.classList.remove('ind-nav__item--active'));
        navItems.find(i=>i.textContent.trim()===ind)?.classList.add('ind-nav__item--active');
      };
      navItems.forEach(navItem => {
        navItem.addEventListener('click',()=>{
          const ind=navItem.textContent.trim();
          if(filterActive&&navItem.classList.contains('ind-nav__item--active')){
            filterActive=false; navItems.forEach(i=>i.classList.remove('ind-nav__item--active')); ctrl.clearFilter();
          } else { filterActive=true; navItems.forEach(i=>i.classList.remove('ind-nav__item--active')); navItem.classList.add('ind-nav__item--active'); ctrl.goToIndustry(ind); ctrl.filterToIndustry(ind); }
        });
      });
    }
  })();
</script>
