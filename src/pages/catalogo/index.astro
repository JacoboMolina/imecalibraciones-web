---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import '../../styles/catalog.css';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Catálogo de Servicios de Calibración — IME Calibraciones | Acreditado EMA y PJLA"
  description="Catálogo de servicios de calibración acreditados. Más de 150 tipos de instrumentos calibrados con trazabilidad CENAM/NIST. Acreditación EMA e internacional PJLA. Industria manufacturera, farmacéutica y automotriz."
>
  <script type="application/ld+json" slot="head">{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Catálogo de Servicios de Calibración — IME Calibraciones",
    "description": "Servicios de calibración acreditados por EMA y PJLA para instrumentos de medición industrial.",
    "url": "https://imecalibraciones.com/catalogo/"
  }</script>

  <script define:vars={{ b }}>window.__BASE__ = b;</script>
  <script src="../../scripts/catalog.js"></script>

  <main>

    <!-- ===== CABECERA DEL CATÁLOGO ===== -->
    <PageHeader
      label="Catálogo de servicios de calibración IME"
      breadcrumb={[{ label: 'Inicio', href: `${b}/` }, { label: 'Catálogo' }]}
      title="Catálogo de Servicios"
      titleAccent="de Calibración"
      subtitle="Calibración acreditada para más de 150 tipos de instrumentos. Trazabilidad CENAM / NIST · Acreditación EMA e internacional PJLA."
      anchors={[
        { label: 'Buscar instrumento', href: '#catalog-search' },
        { label: 'Ver resultados',     href: '#products-grid'  },
      ]}
    />

    <!-- ===== WRAPPER: catálogo de fondo + overlay encima ===== -->
    <div class="wip-wrapper">

      <!-- Catálogo real de fondo (borroso e inactivo) -->
      <div class="catalog-layout container catalog-disabled" aria-hidden="true">

        <aside class="catalog-filters" aria-label="Filtros del catálogo">
          <div class="filters-header">
            <h3 class="filters-header__title">Filtros</h3>
            <button type="button" id="filters-clear" class="filters-clear" aria-label="Limpiar todos los filtros" hidden>Limpiar todo</button>
          </div>
          <div class="catalog-search-bar">
            <svg class="catalog-search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-5.196-5.196m0 0A7.5 7.5 0 105.196 15.804 7.5 7.5 0 0015.804 15.804z"/>
            </svg>
            <input type="search" id="catalog-search" placeholder="Buscar" autocomplete="off" aria-label="Buscar por instrumento o magnitud de calibración">
          </div>
          <details class="filter-group" open>
            <summary class="filter-group-title">Magnitud</summary>
            <div class="filter-group__options" data-filter="magnitud"></div>
          </details>
          <details class="filter-group">
            <summary class="filter-group-title">Acreditación</summary>
            <div class="filter-group__options" data-filter="acreditacion"></div>
          </details>
          <details class="filter-group">
            <summary class="filter-group-title">Categoría</summary>
            <div class="filter-group__options" data-filter="categoria"></div>
          </details>
        </aside>

        <section class="catalog-results" aria-label="Resultados del catálogo">
          <div class="catalog-results-header">
            <span id="results-count" class="results-count" aria-live="polite" aria-atomic="true"></span>
            <label class="sort-label">
              Ordenar:
              <select id="catalog-sort" class="sort-select">
                <option value="magnitud">Magnitud</option>
                <option value="nombre-az">Nombre A–Z</option>
                <option value="nombre-za">Nombre Z–A</option>
              </select>
            </label>
          </div>
          <div id="active-filters" class="active-filters" aria-label="Filtros activos"></div>
          <div id="products-grid" class="products-grid" aria-live="polite" aria-atomic="false" aria-relevant="additions removals"></div>
        </section>

      </div>

      <!-- Overlay encima del catálogo -->
      <div class="wip-overlay" role="status" aria-label="Sección en construcción">
        <div class="wip-card">

          <div class="wip-header">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="wip-icon" aria-hidden="true">
              <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
            </svg>
            <h2 class="wip-title">¡En construcción!</h2>
            <p class="wip-subtitle">Estamos ampliando y mejorando nuestro catálogo.</p>
          </div>

          <div class="wip-body">

          <!-- ── DESCARGABLES ──────────────────────────────────────────── -->
          <!-- Para activar un archivo: reemplaza href="#" con la ruta real -->
          <div class="wip-downloads" aria-label="Documentos descargables">
            <p class="wip-downloads__label">Mientras tanto descarga nuestros catálogos:</p>
            <div class="wip-downloads__list">

              <a href="/assets/pdfs/catalogo-ema.pdf" class="wip-download-btn" download aria-label="Descargar catálogo EMA">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Catálogo EMA
              </a>

              <a href="/assets/pdfs/catalogo-pjla.pdf" class="wip-download-btn" download aria-label="Descargar catálogo PJLA">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Catálogo PJLA
              </a>

            </div>
          </div>

          </div><!-- /wip-body -->

          <a href={`${b}/contacto/`} class="wip-cta">
            Solicitar cotización
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>

        </div>
      </div>

    </div>

  </main>
</Base>

<style>
  /* ── Wrapper relativo que contiene fondo + overlay ─────────── */
  .wip-wrapper {
    position: relative;
  }

  /* ── Catálogo de fondo: borroso e inactivo ─────────────────── */
  .catalog-disabled {
    opacity: .5;
    filter: blur(2px);
    pointer-events: none;
    user-select: none;
  }

  /* ── Overlay flotante encima del catálogo ──────────────────── */
  .wip-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 2.5rem 1rem 4rem;
    background: rgba(255, 255, 255, 0.3);
    z-index: 10;
  }

  .wip-card {
    background: rgba(255, 255, 255, 0.92);
    border-radius: .875rem;
    overflow: hidden;
    width: 100%;
    max-width: 460px;
    box-shadow: 0 12px 48px rgba(0,0,0,.18);
    backdrop-filter: blur(8px);
    text-align: center;
  }

  /* Cabecera oscura */
  .wip-header {
    background: var(--color-primary, #1a3a5c);
    padding: 1.6rem 1.75rem 1.4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
  }

  .wip-icon {
    width: 30px;
    height: 30px;
    color: rgba(255,255,255,.85);
  }

  .wip-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
  }

  .wip-subtitle {
    font-size: .85rem;
    color: rgba(255,255,255,.72);
    margin: 0;
    line-height: 1.5;
  }

  /* Cuerpo blanco */
  .wip-body {
    padding: 1.5rem 1.75rem 0;
  }

  /* ── Descargables ─────────────────────────────────────────── */
  .wip-downloads {
    background: #f4f6f8;
    border-radius: .6rem;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1.25rem;
  }

  .wip-downloads__label {
    font-size: .82rem;
    font-weight: 600;
    color: #555;
    margin-bottom: .75rem;
  }

  .wip-downloads__list {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    justify-content: center;
  }

  .wip-download-btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .65rem 1.25rem;
    border: 2px solid var(--color-primary, #1a3a5c);
    border-radius: .5rem;
    color: var(--color-primary, #1a3a5c);
    font-weight: 600;
    font-size: .9rem;
    text-decoration: none;
    transition: background .2s, color .2s;
  }

  .wip-download-btn:hover {
    background: var(--color-primary, #1a3a5c);
    color: #fff;
  }

  .wip-download-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .wip-cta {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .5rem 1.1rem;
    margin: 1rem 0 1.5rem;
    background: var(--color-primary, #1a3a5c);
    color: #fff;
    border-radius: .5rem;
    font-size: .85rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity .2s;
  }

  .wip-cta:hover { opacity: .85; }

  .wip-cta svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
</style>
