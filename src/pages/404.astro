---
import Base from '../layouts/Base.astro';
---

<Base
  title="Página no encontrada — IME Calibraciones"
  description="Laboratorio de calibración acreditado por EMA y PJLA. Servicio nacional, 32 magnitudes, 31+ años de experiencia. Tlaxcala, México."
>
  <main style="min-height: 70vh; display:flex; align-items:center;">
    <div class="container text-center" style="padding: 80px 24px;">
      <div style="font-size: 6rem; font-weight:800; color: var(--color-line); line-height:1; margin-bottom: 16px;">404</div>
      <h1 style="font-size: 1.75rem; margin-bottom: 12px;">Página no encontrada</h1>
      <p style="color: var(--color-muted); max-width: 440px; margin: 0 auto 32px;">
        La página que buscas no existe o fue movida. Puedes regresar al inicio o explorar nuestro catálogo.
      </p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn btn-primary btn-lg">Ir al inicio</a>
        <a href="/catalogo/" class="btn btn-secondary btn-lg">Ver catálogo</a>
      </div>
    </div>
  </main>
</Base>
