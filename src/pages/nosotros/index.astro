---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { Image } from 'astro:assets';
import equipoIme from '../../assets/images/nosotros/equipo-ime.png';
import bannerNosotros from '../../assets/images/nosotros/banner-nosotros.jpeg';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Nosotros — IME Calibraciones | Laboratorio de Metrología en Tlaxcala"
  description="Conoce a IME Calibraciones: historia, misión, equipo y valores. Laboratorio de calibración acreditado al servicio de la industria mexicana."
>
  <script type="application/ld+json" slot="head">{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "IME Calibraciones",
    "url": "https://imecalibraciones.com",
    "description": "Laboratorio de calibración acreditado por EMA bajo ISO/IEC 17025, al servicio de la industria mexicana desde Tlaxcala.",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Tlaxcala",
      "addressCountry": "MX"
    }
  }</script>

  <main>

    <!-- ===== PAGE HEADER COMPACTO ===== -->
    <PageHeader
      label="Nosotros — IME Calibraciones"
      breadcrumb={[{ label: 'Inicio', href: `${b}/` }, { label: 'Nosotros' }]}
      title="IME"
      titleAccent="CERTIFICADA"
      subtitle="Más de tres décadas ofreciendo a las industrias exactitud en sus mediciones."
      anchors={[
        { label: '¿Quiénes Somos?', href: '#quienes-somos' },
        { label: 'Misión y Visión', href: '#mision-vision' },
        { label: 'Valores',         href: '#valores'       },
        { label: 'Políticas',       href: '#politicas'     },
      ]}
    />

    <!-- ===== HISTORIA / QUIÉNES SOMOS ===== -->
    <section id="quienes-somos" class="section">
      <div class="container">
        <div class="content-with-image content-with-image--reverse">
          <div class="content-with-image__text">
            <h2>¿Quiénes Somos?</h2>
            <p>
              IME Calibraciones es un laboratorio de calibración acreditado por la Entidad Mexicana
              de Acreditación (EMA) bajo la norma ISO/IEC 17025, con sede en Tlaxcala, México.
            </p>
            <p>
              Desde nuestra fundación, nos hemos dedicado a ofrecer servicios de calibración
              metrológica confiables y trazables para empresas de los sectores manufacturero,
              farmacéutico, alimentario y automotriz en toda la República Mexicana.
            </p>
            <p>
              Nuestra trayectoria, respaldada por acreditaciones vigentes y un equipo de técnicos
              especializados, nos posiciona como un aliado estratégico para el aseguramiento de
              la calidad de su empresa.
            </p>
          </div>
          <div class="content-with-image__media">
            <Image src={equipoIme} alt="Equipo IME Calibraciones — técnicos en laboratorio" widths={[600, 900, 1200]} sizes="(max-width:768px) 100vw, 60vw" format="webp" quality={80} />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== MISIÓN Y VISIÓN — Carrusel ===== -->
    <section id="mision-vision" class="section mv-section">
      <div class="container">
        <div class="mv-layout">

          <!-- Foto fija — igual en ambos slides -->
          <div class="mv-photo">
            <Image src={bannerNosotros} alt="Laboratorio IME Calibraciones" width={800} height={600} />
          </div>

          <!-- Columna de texto: carrusel -->
          <div>
            <div class="mv-carousel" id="mvCarousel" aria-label="Misión y Visión">

              <!-- Slide 1: Misión -->
              <div class="mv-slide mv-slide--active" role="tabpanel" aria-label="Misión">
                <div class="mv-slide__content">
                  <p class="section__eyebrow">Nuestra Misión</p>
                  <h2 class="section-title" style="text-align:left">Calidad en cada entrega</h2>
                  <p>Satisfacer las necesidades de nuestros clientes entregándoles servicios de alta calidad en el tiempo establecido, basados en la normatividad, para la conservación de sus instrumentos y equipos.</p>
                  <ul class="video-section__bullets">
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                      Promovemos el desarrollo humano y la mejora tecnológica
                    </li>
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                      Confiabilidad garantizada en proveedores y procesos
                    </li>
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                      Eficiencia y servicio a la sociedad como prioridad
                    </li>
                  </ul>
                </div>
              </div>

              <!-- Slide 2: Visión -->
              <div class="mv-slide" role="tabpanel" aria-label="Visión">
                <div class="mv-slide__content">
                  <p class="section__eyebrow">Nuestra Visión</p>
                  <h2 class="section-title" style="text-align:left">Referentes en metrología</h2>
                  <p>Consolidarse como una empresa reconocida por su alta calidad en el área de metrología, siendo un soporte técnico confiable y profesional para sus clientes.</p>
                  <ul class="video-section__bullets">
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                      Alta calidad reconocida en el área de metrología
                    </li>
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                      Soporte técnico confiable y profesional
                    </li>
                    <li>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                      Reconocimiento nacional e internacional
                    </li>
                  </ul>
                </div>
              </div>

            </div>

            <!-- Dots de navegación -->
            <div class="mv-dots" role="tablist" aria-label="Navegación Misión y Visión">
              <button class="mv-nav-dot mv-nav-dot--active" data-mv-slide="0" aria-label="Misión" aria-selected="true" role="tab"></button>
              <button class="mv-nav-dot" data-mv-slide="1" aria-label="Visión" aria-selected="false" role="tab"></button>
            </div>
          </div>

        </div>

      </div>
    </section>

    <!-- ===== VALORES ===== -->
    <section id="valores" class="section valores-section">
      <div class="container">
        <header class="section__header text-center">
          <p class="section__eyebrow">Lo que nos define</p>
          <h2 class="section-title">Nuestros <span class="valores-accent">Valores</span></h2>
          <p class="section__subtitle">Principios que guían cada servicio y cada relación con nuestros clientes.</p>
        </header>
        <div class="valores-grid">

          <div class="valor-card">
            <div class="valor-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="3" x2="12" y2="21"/>
                <path d="M3 6h18"/>
                <path d="M5 6l2 9h10l2-9"/>
              </svg>
            </div>
            <p class="valor-card__name">Imparcialidad</p>
            <p class="valor-card__desc">Independencia técnica en cada servicio, sin influencias externas.</p>
          </div>

          <div class="valor-card">
            <div class="valor-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <p class="valor-card__name">Confiabilidad</p>
            <p class="valor-card__desc">Cada calibración cuenta con trazabilidad y procesos rigurosos, brindando resultados confiables para una mejor toma de decisiones.</p>
          </div>

          <div class="valor-card">
            <div class="valor-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <polyline points="9 12 11 14 15 10"/>
              </svg>
            </div>
            <p class="valor-card__name">Integridad</p>
            <p class="valor-card__desc">Cumplimiento riguroso de todos los requisitos normativos y técnicos.</p>
          </div>

          <div class="valor-card">
            <div class="valor-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="2"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                <path d="M2 12h20"/>
              </svg>
            </div>
            <p class="valor-card__name">Excelencia Técnica</p>
            <p class="valor-card__desc">Técnicos signatarios titulados y acreditados.</p>
          </div>

          <div class="valor-card">
            <div class="valor-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <p class="valor-card__name">Compromiso</p>
            <p class="valor-card__desc">Cumplimos cada entrega con los tiempos y estándares acordados.</p>
          </div>

          <div class="valor-card">
            <div class="valor-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <p class="valor-card__name">Responsabilidad</p>
            <p class="valor-card__desc">Actuamos con seriedad y profesionalismo ante cada reto y resultado.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== REDES SOCIALES ===== -->
    <section class="section section--alt nosotros-redes">
      <div class="container">
        <header class="section__header text-center">
          <p class="section__eyebrow">Síguenos</p>
          <h2 class="section-title">Encuéntranos en redes</h2>
          <p class="section__subtitle text-muted">Contenido sobre calibración, metrología y novedades del laboratorio.</p>
        </header>

        <!-- Videos: TikTok + Instagram Reel -->
        <div class="nosotros-redes__embeds">

          <div class="nosotros-redes__embed-wrap">
            <p class="nosotros-redes__embed-label">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="14" height="14"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.53V6.77a4.85 4.85 0 01-1.02-.08z"/></svg>
              TikTok
            </p>
            <iframe
              src="https://www.tiktok.com/embed/v2/7541801257854455046"
              width="280"
              height="500"
              frameborder="0"
              allow="encrypted-media"
              allowfullscreen
              loading="lazy"
              title="Video TikTok — IME Calibraciones"
            ></iframe>
          </div>

          <div class="nosotros-redes__embed-wrap">
            <p class="nosotros-redes__embed-label">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="14" height="14"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              Instagram
            </p>
            <iframe
              src="https://www.instagram.com/reel/DWFYQpsjyZX/embed/"
              width="280"
              height="500"
              frameborder="0"
              scrolling="no"
              allowtransparency="true"
              loading="lazy"
              title="Reel Instagram — IME Calibraciones"
            ></iframe>
          </div>

          <div class="nosotros-redes__embed-wrap">
            <p class="nosotros-redes__embed-label">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="14" height="14"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </p>
            <iframe
              src="https://www.youtube.com/embed/RKeehJbrhS0"
              width="280"
              height="500"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              title="YouTube Short — IME Calibraciones"
            ></iframe>
          </div>

        </div>

        <!-- Links de redes -->
        <div class="nosotros-redes__icons">
          <a href="https://www.tiktok.com/@calibracionesime" target="_blank" rel="noopener noreferrer" class="nosotros-red" aria-label="TikTok">
            <span class="nosotros-red__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.53V6.77a4.85 4.85 0 01-1.02-.08z"/></svg>
            </span>
            <span class="nosotros-red__label">@calibracionesime</span>
          </a>
          <a href="https://www.instagram.com/calibracionesime/" target="_blank" rel="noopener noreferrer" class="nosotros-red" aria-label="Instagram">
            <span class="nosotros-red__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </span>
            <span class="nosotros-red__label">@calibracionesime</span>
          </a>
          <a href="https://www.facebook.com/CalibracionIME" target="_blank" rel="noopener noreferrer" class="nosotros-red" aria-label="Facebook">
            <span class="nosotros-red__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </span>
            <span class="nosotros-red__label">CalibracionIME</span>
          </a>
          <a href="https://www.youtube.com/shorts/RKeehJbrhS0" target="_blank" rel="noopener noreferrer" class="nosotros-red" aria-label="YouTube">
            <span class="nosotros-red__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </span>
            <span class="nosotros-red__label">YouTube Shorts</span>
          </a>
          <a href="https://mx.linkedin.com/company/calibracionesime" target="_blank" rel="noopener noreferrer" class="nosotros-red" aria-label="LinkedIn">
