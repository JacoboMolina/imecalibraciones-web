<style>
/* ============================================================
   NOSOTROS — Misión & Visión + Valores
   ============================================================ */

/* ── Misión & Visión — Carrusel ── */
.mv-section {
  background: linear-gradient(135deg, #041a39 0%, #063d73 100%);
  position: relative;
  overflow: hidden;
}
.mv-section::before {
  content: '';
  position: absolute;
  width: 520px; height: 520px;
  border-radius: 50%;
  top: -180px; right: -150px;
  background: rgba(147, 197, 253, 0.04);
  pointer-events: none;
}

.mv-section .section__eyebrow { color: #93c5fd; }
.mv-section .section-title    { color: #fff; }
.mv-section p                  { color: rgba(255, 255, 255, .75); }

/* Layout foto + carrusel texto */
.mv-layout {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: var(--space-16);
  align-items: center;
}

/* Foto fija */
.mv-photo {
  aspect-ratio: 4 / 3;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(8, 82, 154, .18), 0 4px 16px rgba(0, 0, 0, .1);
}
.mv-photo img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

/* Carousel */
.mv-carousel { position: relative; }

.mv-slide { display: none; }
.mv-slide--active {
  display: block;
  animation: mvFadeIn .45s ease;
}
@keyframes mvFadeIn {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0);    }
}

/* Content dentro de cada slide */
.mv-slide__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  padding: var(--space-4) 0 var(--space-6);
}

/* Navigation dots */
.mv-dots {
  display: flex;
  justify-content: flex-start;
  gap: var(--space-3);
  padding-top: var(--space-6);
}
.mv-nav-dot {
  height: 8px; width: 8px;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, .3);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: width .3s ease, background .3s ease;
}
.mv-nav-dot--active {
  width: 28px;
  background: #93c5fd;
}

@media (max-width: 860px) {
  .mv-layout {
    grid-template-columns: 1fr;
  }
  .mv-photo { display: none; }
  .mv-slide__content { text-align: center; }
  .mv-slide__content .section-title { text-align: center !important; }
  .mv-slide__content .video-section__bullets { align-items: center; }
  .mv-dots { justify-content: center; }
}

/* ── Valores ── */
.valores-section { background: var(--color-surface); }

.valores-accent { color: var(--color-primary); }

.valores-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
}

.valor-card {
  background: #ffffff;
  border-radius: var(--radius-lg);
  padding: var(--space-6) var(--space-5);
  border: 1px solid var(--color-line);
