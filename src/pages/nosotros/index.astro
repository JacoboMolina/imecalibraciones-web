---
import Base from '../../layouts/Base.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Nosotros — IME Calibraciones | Laboratorio de Metrología en Tlaxcala"
  description="Conoce a IME Calibraciones: historia, misión, equipo y valores. Laboratorio de calibración acreditado al servicio de la industria mexicana."
>
  <script type="application/ld+json" slot="head">{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "IME Calibraciones",
    "url": "https://imecalibraciones.com",
    "description": "Laboratorio de calibración acreditado por EMA bajo ISO/IEC 17025, al servicio de la industria mexicana desde Tlaxcala.",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Tlaxcala",
      "addressCountry": "MX"
    }
  }</script>

  <main>

    <!-- ===== PAGE HERO ===== -->
    <section class="page-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Ruta de navegación">
          <ol>
            <li><a href={`${b}/`}>Inicio</a></li>
            <li aria-current="page">Nosotros</li>
          </ol>
        </nav>
        <h1>Nosotros</h1>
        <p class="page-hero__subtitle">
          Más de dos décadas de experiencia en metrología y calibración industrial,
          al servicio de la industria mexicana desde Tlaxcala.
        </p>
      </div>
    </section>

    <!-- ===== HISTORIA / QUIÉNES SOMOS ===== -->
    <section class="section">
      <div class="container">
        <div class="content-with-image content-with-image--reverse">
          <div class="content-with-image__text">
            <h2>¿Quiénes Somos?</h2>
            <!-- TODO: textos definitivos pendientes del cliente.
                 Usar texto del sitio actual como base para redacción final.
                 Incluir: año de fundación, sector al que sirven, diferenciadores clave. -->
            <p>
              IME Calibraciones es un laboratorio de calibración acreditado por la Entidad Mexicana
              de Acreditación (EMA) bajo la norma ISO/IEC 17025, con sede en Tlaxcala, México.
            </p>
            <p>
              <!-- TODO: textos definitivos — historia de la empresa, años de operación, hitos importantes -->
              Desde nuestra fundación, nos hemos dedicado a ofrecer servicios de calibración
              metrológica confiables y trazables para empresas de los sectores manufacturero,
              farmacéutico, alimentario y automotriz en toda la República Mexicana.
            </p>
            <p>
              <!-- TODO: agregar diferenciadores reales con datos del cliente -->
              Nuestra trayectoria, respaldada por acreditaciones vigentes y un equipo de técnicos
              especializados, nos posiciona como un aliado estratégico para el aseguramiento de
              la calidad de su empresa.
            </p>
          </div>
          <div class="content-with-image__media">
            <!-- TODO: FOTO REAL — laboratorio IME, instalaciones, equipo de calibración. Fondo limpio. -->
            <div class="image-placeholder" aria-hidden="true">
              <span>Foto: Instalaciones del laboratorio</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== MISIÓN Y VISIÓN ===== -->
    <section class="section section--alt">
      <div class="container">
        <h2>Misión y Visión</h2>
        <!-- TODO: textos definitivos de misión y visión pendientes del cliente -->
        <div class="mision-vision-grid">
          <div class="card card--mision">
            <h3 class="card__title">Misión</h3>
            <p class="card__body">
              <!-- TODO: texto definitivo de misión -->
              Proporcionar servicios de calibración acreditados, confiables y oportunos que
              contribuyan al aseguramiento de la calidad y la trazabilidad metrológica de
              nuestros clientes, apoyando su competitividad en la industria nacional e internacional.
            </p>
          </div>
          <div class="card card--vision">
            <h3 class="card__title">Visión</h3>
            <p class="card__body">
              <!-- TODO: texto definitivo de visión -->
              Ser el laboratorio de calibración de referencia en México, reconocido por la
              excelencia técnica, la imparcialidad y el compromiso con la mejora continua
              en el servicio a la industria mexicana.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== VALORES ===== -->
    <section class="section">
      <div class="container">
        <h2>Nuestros Valores</h2>
        <!-- TODO: confirmar lista de valores con el equipo de IME -->
        <div class="cards-grid cards-grid--valores">
          <div class="card card--valor">
            <h3 class="card__title">Confiabilidad</h3>
            <p class="card__body">Cada medición que certificamos está respaldada por trazabilidad y procedimientos rigurosos.</p>
          </div>
          <div class="card card--valor">
            <h3 class="card__title">Imparcialidad</h3>
            <p class="card__body">Operamos con independencia técnica y libre de influencias externas en nuestros resultados.</p>
          </div>
          <div class="card card--valor">
            <h3 class="card__title">Excelencia técnica</h3>
            <p class="card__body">Formación continua, equipos calibrados y procesos documentados para garantizar la calidad.</p>
          </div>
          <div class="card card--valor">
            <h3 class="card__title">Compromiso</h3>
            <p class="card__body">Entendemos las necesidades de cada cliente y cumplimos con tiempos y estándares acordados.</p>
          </div>
          <div class="card card--valor">
            <h3 class="card__title">Mejora continua</h3>
            <p class="card__body">Revisamos y mejoramos constantemente nuestros procedimientos y sistema de gestión.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== EQUIPO ===== -->
    <section class="section section--alt">
      <div class="container">
        <h2>Nuestro Equipo</h2>
        <p class="section__subtitle">
          <!-- TODO: descripción del equipo pendiente. Confirmar número de técnicos y especialidades. -->
          Un equipo de técnicos especializados con formación en metrología y amplia experiencia
          en calibración industrial.
        </p>
        <!-- TODO: FOTO REAL — personas en laboratorio, atuendo profesional (bata/uniforme), fondo limpio.
             Reemplazar las tarjetas placeholder por fotos y datos reales del equipo. -->
        <div class="team-grid">

          <div class="card card--team">
            <div class="card__photo">
              <!-- TODO: FOTO REAL del integrante del equipo -->
              <div class="image-placeholder image-placeholder--person" aria-hidden="true">
                <span>Foto</span>
              </div>
            </div>
            <h3 class="card__title">
              <!-- TODO: nombre real -->
              Nombre del Responsable
            </h3>
            <p class="card__subtitle">
              <!-- TODO: cargo real -->
              Director / Responsable Técnico
            </p>
            <p class="card__body">
              <!-- TODO: breve bio -->
            </p>
          </div>

          <div class="card card--team">
            <div class="card__photo">
              <!-- TODO: FOTO REAL del integrante del equipo -->
              <div class="image-placeholder image-placeholder--person" aria-hidden="true">
                <span>Foto</span>
              </div>
            </div>
            <h3 class="card__title">
              <!-- TODO: nombre real -->
              Nombre del Técnico 1
            </h3>
            <p class="card__subtitle">
              <!-- TODO: cargo real, p.ej. "Técnico en Temperatura" -->
              Técnico de Calibración
            </p>
            <p class="card__body">
              <!-- TODO: breve bio -->
            </p>
          </div>

          <div class="card card--team">
            <div class="card__photo">
              <!-- TODO: FOTO REAL del integrante del equipo -->
              <div class="image-placeholder image-placeholder--person" aria-hidden="true">
                <span>Foto</span>
              </div>
            </div>
            <h3 class="card__title">
              <!-- TODO: nombre real -->
              Nombre del Técnico 2
            </h3>
            <p class="card__subtitle">
              <!-- TODO: cargo real -->
              Técnico de Calibración
            </p>
            <p class="card__body">
              <!-- TODO: breve bio -->
            </p>
          </div>

          <!-- TODO: agregar tarjetas para todos los integrantes del equipo -->

        </div>
      </div>
    </section>

    <!-- ===== INSTALACIONES ===== -->
    <section class="section">
      <div class="container">
        <h2>Nuestras Instalaciones</h2>
        <p class="section__subtitle">
          Laboratorio equipado con instrumentos patrón calibrados y trazados, en condiciones
          ambientales controladas para garantizar la exactitud de cada calibración.
        </p>
        <!-- TODO: FOTO REAL — laboratorio, equipo de calibración, instalaciones limpias y bien iluminadas.
             Mínimo 4-6 fotos de alta calidad para la galería. Fondo limpio, iluminación profesional. -->
        <div class="gallery-grid">

          <figure class="gallery-item">
            <!-- TODO: reemplazar con imagen real -->
            <div class="image-placeholder image-placeholder--landscape" aria-hidden="true">
              <span>Foto: Área de calibración de temperatura</span>
            </div>
            <figcaption>Área de calibración de temperatura</figcaption>
          </figure>

          <figure class="gallery-item">
            <!-- TODO: reemplazar con imagen real -->
            <div class="image-placeholder image-placeholder--landscape" aria-hidden="true">
              <span>Foto: Equipos patrón</span>
            </div>
            <figcaption>Equipos patrón de referencia</figcaption>
          </figure>

          <figure class="gallery-item">
            <!-- TODO: reemplazar con imagen real -->
            <div class="image-placeholder image-placeholder--landscape" aria-hidden="true">
              <span>Foto: Área de calibración dimensional</span>
            </div>
            <figcaption>Área de calibración dimensional</figcaption>
          </figure>

          <figure class="gallery-item">
            <!-- TODO: reemplazar con imagen real -->
            <div class="image-placeholder image-placeholder--landscape" aria-hidden="true">
              <span>Foto: Vista general del laboratorio</span>
            </div>
            <figcaption>Vista general del laboratorio</figcaption>
          </figure>

          <!-- TODO: agregar más fotos reales de las instalaciones -->

        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="section section--cta">
      <div class="container container--narrow text-center">
        <h2>¿Le gustaría conocer más?</h2>
        <p>Contáctenos para obtener información sobre nuestros servicios o agendar una visita.</p>
        <div class="cta-actions">
          <a href={`${b}/contacto/`} class="btn btn--primary btn--lg">Contáctanos</a>
          <a href={`${b}/acreditaciones/`} class="btn btn--outline btn--lg">Ver acreditaciones</a>
        </div>
      </div>
    </section>

  </main>
</Base>
