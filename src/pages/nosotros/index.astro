}

</style>

<script>
(function () {
  const slides = document.querySelectorAll('#mvCarousel .mv-slide');
  const dots   = document.querySelectorAll('.mv-nav-dot');
  if (!slides.length) return;

  let current = 0;
  let timer;

  function goTo(idx) {
    slides[current].classList.remove('mv-slide--active');
    dots[current].classList.remove('mv-nav-dot--active');
    dots[current].setAttribute('aria-selected', 'false');
    current = (idx + slides.length) % slides.length;
    slides[current].classList.add('mv-slide--active');
    dots[current].classList.add('mv-nav-dot--active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      timer = setInterval(() => goTo((current + 1) % slides.length), 7000);
    });
  });

  timer = setInterval(() => goTo((current + 1) % slides.length), 7000);
})();
</script>
