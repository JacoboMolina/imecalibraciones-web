              src="https://www.tiktok.com/embed/v2/7541801257854455046"
              width="280"
              height="500"
              frameborder="0"
              allow="encrypted-media"
              allowfullscreen
              loading="lazy"
              title="Video TikTok — IME Calibraciones"
            ></iframe>
          </div>

          <div class="nosotros-redes__embed-wrap">
            <p class="nosotros-redes__embed-label">
