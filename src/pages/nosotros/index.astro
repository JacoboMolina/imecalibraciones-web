<style>
/* ============================================================
   NOSOTROS — Misión & Visión + Valores
   ============================================================ */

/* ── Misión & Visión — Carrusel ── */
.mv-section {
  background: linear-gradient(135deg, #041a39 0%, #063d73 100%);
  position: relative;
  overflow: hidden;
}
.mv-section::before {
  content: '';
  position: absolute;
  width: 520px; height: 520px;
  border-radius: 50%;
  top: -180px; right: -150px;
  background: rgba(147, 197, 253, 0.04);
  pointer-events: none;
}

.mv-section .section__eyebrow { color: #93c5fd; }
.mv-section .section-title    { color: #fff; }
.mv-section p                  { color: rgba(255, 255, 255, .75); }

/* Carousel */
.mv-carousel { position: relative; }

.mv-slide { display: none; }
.mv-slide--active {
  display: block;
  animation: mvFadeIn .45s ease;
}
@keyframes mvFadeIn {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0);    }
}

/* Slide layout — igual que video-section__layout */
.mv-slide__layout {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: var(--space-16);
  align-items: center;
  padding: var(--space-4) 0 var(--space-8);
}

/* Media — icono decorativo */
.mv-slide__media {
  aspect-ratio: 4 / 3;
  border-radius: var(--radius-xl);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 20px 60px rgba(8, 82, 154, .18), 0 4px 16px rgba(0, 0, 0, .1);
  display: flex;
  align-items: center;
  justify-content: center;
}
.mv-slide__icon-ring {
  width: 58%;
  aspect-ratio: 1;
  display: flex; align-items: center; justify-content: center;
}
.mv-slide__icon-ring svg {
  width: 100%; height: 100%;
  stroke: rgba(147, 197, 253, .35);
}

/* Content */
.mv-slide__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

/* Navigation dots */
.mv-dots {
  display: flex;
  justify-content: center;
  gap: var(--space-3);
  padding-top: var(--space-8);
}
.mv-nav-dot {
  height: 8px; width: 8px;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, .3);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: width .3s ease, background .3s ease;
}
.mv-nav-dot--active {
  width: 28px;
  background: #93c5fd;
}

@media (max-width: 860px) {
  .mv-slide__layout {
    grid-template-columns: 1fr;
