---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Bolsa de Trabajo — IME Calibraciones"
  description="Únete al equipo de IME Calibraciones. Consulta nuestras vacantes y envía tu solicitud."
>
  <main>

    <PageHeader
      label="Bolsa de trabajo — IME Calibraciones"
      breadcrumb={[{ label: 'Inicio', href: `${b}/` }, { label: 'Bolsa de trabajo' }]}
      title="Bolsa de trabajo"
      subtitle="Forma parte del equipo de IME Calibraciones y contribuye al desarrollo de la metrología en México."
      anchors={[
        { label: 'Ver vacantes', href: '#vacantes' },
        { label: 'Enviar CV',    href: '#formulario-cv' },
      ]}
      video={`${b}/assets/video/hero-lab.mp4`}
      poster={`${b}/assets/images/hero/hero-poster.png`}
    />

    <section class="section">
      <div class="container container--narrow">

        <!-- TODO: reemplazar con vacantes reales cuando las haya -->
        <div id="vacantes" class="bolsa-aviso">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm8.706-1.442c1.146-.573 2.437.463 2.126 1.706l-.709 2.836.042-.02a.75.75 0 01.67 1.34l-.04.022c-1.147.573-2.438-.463-2.127-1.706l.71-2.836-.042.02a.75.75 0 11-.671-1.34l.041-.022zM12 9a.75.75 0 100-1.5.75.75 0 000 1.5z" clip-rule="evenodd"/></svg>
          <p>Por el momento no tenemos vacantes abiertas. Si deseas dejar tu currículum para futuras oportunidades, completa el formulario a continuación.</p>
        </div>

        <form id="formulario-cv" class="contacto-form bolsa-form" action="#" method="POST" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="bolsa-nombre">Nombre completo <span aria-hidden="true">*</span></label>
              <input type="text" id="bolsa-nombre" name="nombre" required autocomplete="name" placeholder="Juan García">
            </div>
            <div class="form-group">
              <label for="bolsa-email">Correo electrónico <span aria-hidden="true">*</span></label>
              <input type="email" id="bolsa-email" name="email" required autocomplete="email" placeholder="correo@ejemplo.com">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="bolsa-telefono">Teléfono</label>
              <input type="tel" id="bolsa-telefono" name="telefono" autocomplete="tel" placeholder="(222) 123-4567">
            </div>
            <div class="form-group">
              <label for="bolsa-puesto">Área de interés</label>
              <select id="bolsa-puesto" name="puesto">
                <option value="">Selecciona una opción</option>
                <option value="tecnico-calibracion">Técnico de calibración</option>
                <option value="laboratorio">Laboratorio</option>
                <option value="administrativo">Administrativo</option>
                <option value="ventas">Ventas / Atención a clientes</option>
                <option value="otro">Otro</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="bolsa-mensaje">Mensaje / presentación breve</label>
            <textarea id="bolsa-mensaje" name="mensaje" rows="4" placeholder="Cuéntanos sobre tu experiencia y por qué te gustaría unirte a IME..."></textarea>
          </div>
          <div class="form-group">
            <label for="bolsa-cv">Currículum (PDF, máx. 5 MB)</label>
            <input type="file" id="bolsa-cv" name="cv" accept=".pdf">
          </div>
          <button type="submit" class="btn btn-primary">Enviar solicitud</button>
        </form>

      </div>
    </section>

  </main>
</Base>

<style>
.bolsa-aviso {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: var(--radius-lg);
  padding: var(--space-4) var(--space-5);
  margin-bottom: var(--space-8);
  color: #1e40af;
}
.bolsa-aviso svg { width: 20px; height: 20px; flex-shrink: 0; margin-top: 2px; }
.bolsa-aviso p { margin: 0; font-size: var(--text-sm); line-height: 1.6; }
.bolsa-form .form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}
@media (max-width: 600px) {
  .bolsa-form .form-row { grid-template-columns: 1fr; }
}
</style>
