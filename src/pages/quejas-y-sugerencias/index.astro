---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Quejas y Sugerencias — IME Calibraciones"
  description="Comparte tu experiencia con IME Calibraciones. Tus quejas y sugerencias nos ayudan a mejorar."
>
  <main>

    <PageHeader
      label="Quejas y sugerencias — IME Calibraciones"
      breadcrumb={[{ label: 'Inicio', href: `${b}/` }, { label: 'Quejas y sugerencias' }]}
      title="Quejas y Sugerencias"
      subtitle="Tu opinión es importante para nosotros. Nos comprometemos a atender cada comentario con la seriedad que merece."
      anchors={[
        { label: 'Enviar comentario', href: '#formulario-quejas' },
      ]}
      video={`${b}/assets/video/hero-lab.mp4`}
      poster={`${b}/assets/images/hero/hero-poster.png`}
    />

    <section class="section">
      <div class="container container--narrow">

        <form id="formulario-quejas" class="contacto-form quejas-form" action="#" method="POST" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="quejas-nombre">Nombre completo <span aria-hidden="true">*</span></label>
              <input type="text" id="quejas-nombre" name="nombre" required autocomplete="name" placeholder="Juan García">
            </div>
            <div class="form-group">
              <label for="quejas-email">Correo electrónico <span aria-hidden="true">*</span></label>
              <input type="email" id="quejas-email" name="email" required autocomplete="email" placeholder="correo@ejemplo.com">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="quejas-tipo">Tipo de comentario <span aria-hidden="true">*</span></label>
              <select id="quejas-tipo" name="tipo" required>
                <option value="">Selecciona una opción</option>
                <option value="queja">Queja</option>
                <option value="sugerencia">Sugerencia</option>
                <option value="felicitacion">Felicitación</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label for="quejas-folio">N.º de certificado o folio (opcional)</label>
              <input type="text" id="quejas-folio" name="folio" placeholder="Ej. IME-2025-0123">
            </div>
          </div>
          <div class="form-group">
            <label for="quejas-mensaje">Descripción <span aria-hidden="true">*</span></label>
            <textarea id="quejas-mensaje" name="mensaje" rows="5" required placeholder="Describe tu queja o sugerencia con el mayor detalle posible..."></textarea>
          </div>
          <div class="quejas-aviso">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 00-5.25 5.25v3a3 3 0 00-3 3v6.75a3 3 0 003 3h10.5a3 3 0 003-3v-6.75a3 3 0 00-3-3v-3c0-2.9-2.35-5.25-5.25-5.25zm3.75 8.25v-3a3.75 3.75 0 10-7.5 0v3h7.5z" clip-rule="evenodd"/></svg>
            <p>Tu información es confidencial. Nos comprometemos a darte respuesta en un plazo máximo de <strong>5 días hábiles</strong>.</p>
          </div>
          <button type="submit" class="btn btn-primary">Enviar comentario</button>
        </form>

      </div>
    </section>

  </main>
</Base>

<style>
.quejas-form .form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}
.quejas-aviso {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-5);
  color: #166534;
  font-size: var(--text-sm);
}
.quejas-aviso svg { width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px; }
.quejas-aviso p { margin: 0; line-height: 1.6; }
@media (max-width: 600px) {
  .quejas-form .form-row { grid-template-columns: 1fr; }
}
</style>
