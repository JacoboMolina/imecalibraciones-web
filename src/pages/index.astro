---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { clientes } from '../data/clientes';
import slide1 from '../assets/images/hero/slide-1.png';
import slide2 from '../assets/images/hero/slide-2.png';
import slide3 from '../assets/images/hero/slide-3.png';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="IME Calibraciones — Laboratorio Acreditado en Tlaxcala, México"
  description="Calibración acreditada de instrumentos de medición. Trazabilidad nacional e internacional. Servicio para industria manufacturera, farmacéutica y automotriz en México."
>

  <!-- Preload del video hero para mejorar LCP -->
  <link rel="preload" as="video" href={`${b}/assets/video/hero-lab.mp4`} type="video/mp4" slot="head">

  <!-- Schema JSON-LD específico del home -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://imecalibraciones.com/#organization",
        "name": "IME Calibraciones",
        "legalName": "Ingeniería y Metrología Certificada Para Calibración de Equipos de Control y Pruebas S.A. de C.V.",
        "url": "https://imecalibraciones.com",
        "logo": "https://imecalibraciones.com/assets/images/logo/logo-ime.svg",
        "telephone": "+522461261782",
        "email": "contacto@imecalibraciones.com",
        "sameAs": [
          "https://www.facebook.com/CalibracionIME",
          "https://www.instagram.com/calibracionesime/",
          "https://www.youtube.com/@CalibracionesIME",
          "https://mx.linkedin.com/company/calibracionesime"
        ]
      },
      {
        "@type": "LocalBusiness",
        "@id": "https://imecalibraciones.com/#localbusiness",
        "name": "IME Calibraciones",
        "description": "Laboratorio de calibración acreditado por EMA bajo ISO/IEC 17025.",
        "telephone": "+522461261782",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Tlaxcala",
          "addressRegion": "Tlaxcala",
          "addressCountry": "MX"
        },
        "url": "https://imecalibraciones.com",
        "priceRange": "$$"
      },
      {
        "@type": "WebSite",
        "@id": "https://imecalibraciones.com/#website",
        "url": "https://imecalibraciones.com",
        "name": "IME Calibraciones",
        "publisher": { "@id": "https://imecalibraciones.com/#organization" }
      }
    ]
  }
  </script>

  <main>

    <!-- ══ SECCIÓN 1: HERO ══ -->
    <section class="hero" id="hero" aria-label="Presentación IME Calibraciones">

      <div class="hero__bg" aria-hidden="true">
        <div class="hero__carousel" id="heroCarousel">
          <div class="hero__slide hero__slide--video hero__slide--active">
            <video autoplay muted loop playsinline poster={`${b}/assets/images/hero/hero-poster.png`} fetchpriority="high">
              <source src={`${b}/assets/video/hero-lab.mp4`} type="video/mp4">
            </video>
          </div>
          <div class="hero__slide">
            <Image src={slide1} alt="Laboratorio de calibración IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="eager" format="webp" quality={80} />
          </div>
          <div class="hero__slide">
            <Image src={slide2} alt="Instrumentos de medición calibrados por IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="eager" format="webp" quality={80} />
          </div>
          <div class="hero__slide">
            <Image src={slide3} alt="Equipo de metrólogos certificados IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="eager" format="webp" quality={80} />
          </div>
        </div>
        <div class="hero__overlay"></div>
        <div class="hero__bg-pattern"></div>
      </div>

      <div class="container">
        <div class="hero__content">
          <div class="hero__badges" aria-label="Acreditaciones">
            <div class="hero__badge">
              <svg class="hero__badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
              </svg>
              <span>EMA&nbsp;·&nbsp;ISO/IEC 17025</span>
            </div>
            <div class="hero__badge">
              <svg class="hero__badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
              </svg>
              <span>PJLA No. 54194</span>
            </div>
          </div>

          <div class="hero__text">
            <h1 class="hero__title hero__title--long" id="heroTitle">
              Ingeniería y Metrología <span class="hero__title-highlight">Certificada</span><br>
              Para <span class="hero__title-highlight">Calibración</span>
            </h1>

            <p class="hero__subtitle" id="heroSubtitle">
              de Equipos de Control y Pruebas S.A. de C.V.
            </p>
          </div>

          <div class="hero__actions">
            <a href={`${b}/contacto/`} class="btn btn-primary btn-lg hero__cta-primary">
              Solicitar cotización
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
              </svg>
            </a>
            <a href={`${b}/catalogo/`} class="btn btn-outline-white btn-lg">Ver catálogo de instrumentos</a>
          </div>
        </div>
      </div>

      <!-- Progress bars estilo Instagram -->
      <div class="hero__progress-bars" aria-hidden="true">
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
      </div>

      <div class="hero__trust" aria-label="Indicadores clave">
        <ul class="hero__stats" role="list">
          <li class="hero__stat">
            <strong class="hero__stat-value">
              <span class="counter" data-target="30" data-suffix="+">30+</span>
            </strong>
            <span class="hero__stat-label">Años de<br>experiencia</span>
          </li>
          <li class="hero__stat">
            <strong class="hero__stat-value">
              <span class="counter" data-target="32">32</span>
            </strong>
            <span class="hero__stat-label">Magnitudes acreditadas<br>ante PJLA</span>
          </li>
          <li class="hero__stat">
            <strong class="hero__stat-value">
              <span class="counter" data-target="7">7</span>
            </strong>
            <span class="hero__stat-label">Magnitudes acreditadas<br>ante EMA</span>
          </li>
          <li class="hero__stat">
            <strong class="hero__stat-value hero__stat-value--text">ISO/IEC 17025</strong>
            <span class="hero__stat-label">Norma de<br>acreditación vigente</span>
          </li>
        </ul>
      </div>

      <div class="hero__scroll-hint" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>

      <!-- Tira de magnitudes -->
      <div class="magnitudes-strip" id="magnitudes" aria-label="Magnitudes de calibración">
        <div class="magnitudes-strip__track-wrap" aria-hidden="true">
          <ul class="magnitudes-strip__track" role="list">
            {(m => [...m, ...m])(['Eléctrica','Presión','Temperatura termodinámica','%H.R.','Óptica','Turbidez','Tiempo','Acústica','Masa','Fuerza','Tensión','Velocidad del aire','Velocidad Lineal','Tensión Superficial','Torque','Dureza','Volumen','Densidad','Concentración de Alcohol','Vibración','Flujo','Viscosidad','pH','Conductividad','Cloro','Oxígeno Disuelto','Dimensional','Mediciones especiales','%Humedad','Frecuencia','Coeficiente de Fricción','Ondas de Radio']).map((m, i) => (
              <li aria-hidden={i >= 32 ? 'true' : undefined}>
                <span class="magnitudes-strip__dot"></span>{m}
              </li>
            ))}
          </ul>
        </div>
        <p class="sr-only">IME Calibraciones calibra 32 magnitudes: Eléctrica, Presión, Temperatura termodinámica, %H.R., Óptica, Turbidez, Tiempo, Acústica, Masa, Fuerza, Tensión, Velocidad del aire, Velocidad Lineal, Tensión Superficial, Torque, Dureza, Volumen, Densidad, Concentración de Alcohol, Vibración, Flujo, Viscosidad, pH, Conductividad, Cloro, Oxígeno Disuelto, Dimensional, Mediciones especiales, %Humedad, Frecuencia, Coeficiente de Fricción y Ondas de Radio.</p>
      </div>

    </section>

    <!-- ══ SECCIÓN 3: CADENA DE VALOR ══ -->
    <section class="section porque-ime" id="porque-ime">
      <div class="container">
        <header class="section__header text-center">
          <p class="section__eyebrow">¿Por qué elegirnos?</p>
          <h2 class="section-title">Lo que diferencia a IME</h2>
          <p class="section__subtitle text-muted">Lo que nos hace distintos, en números.</p>
        </header>
        <div class="dif-carousel">
          <button class="dif-carousel__arrow dif-carousel__arrow--prev" aria-label="Anterior" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 010 1.06L8.06 10l3.72 3.72a.75.75 0 11-1.06 1.06l-4.25-4.25a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 0z" clip-rule="evenodd"/></svg>
          </button>

          <div class="dif-carousel__viewport">
            <div class="dif-carousel__track diferenciadores-grid">

              <article class="dif-stat dif-stat--gold">
                <div class="dif-stat__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/></svg>
                </div>
                <div class="dif-stat__value">EMA + PJLA</div>
                <p class="dif-stat__label">Única doble acreditación ISO/IEC 17025 en México</p>
              </article>

              <article class="dif-stat dif-stat--blue">
                <div class="dif-stat__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.25 5.337c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.036 1.007-1.875 2.25-1.875S15 2.34 15 3.375c0 .369-.128.713-.349 1.003-.215.283-.401.604-.401.959 0 .332.278.598.61.578 1.91-.114 3.79-.342 5.632-.676a.75.75 0 01.878.645 49.17 49.17 0 01.376 5.452.657.657 0 01-.66.664c-.354 0-.675-.186-.958-.401a1.647 1.647 0 00-1.003-.349c-1.035 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401.31 0 .557.262.534.571a48.774 48.774 0 01-.595 4.845.75.75 0 01-.61.61c-1.82.317-3.673.533-5.555.642a.58.58 0 01-.611-.581c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.035-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959a.641.641 0 01-.658.643 49.118 49.118 0 01-4.708-.36.75.75 0 01-.645-.878c.293-1.614.504-3.257.629-4.924A.53.53 0 005.337 15c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.036 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.369 0 .713.128 1.003.349.283.215.604.401.959.401a.656.656 0 00.659-.663 47.703 47.703 0 00-.31-4.82.75.75 0 01.83-.832c1.343.155 2.703.254 4.077.294a.64.64 0 00.657-.642z"/></svg>
                </div>
                <div class="dif-stat__value">24,000</div>
                <p class="dif-stat__label">Equipos calibrados por año — un solo proveedor para toda su planta</p>
              </article>

              <article class="dif-stat dif-stat--green">
                <div class="dif-stat__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd"/></svg>
                </div>
                <div class="dif-stat__value">365 días</div>
                <p class="dif-stat__label">Servicio en cualquier estado, adaptado a sus turnos y horarios</p>
              </article>

              <article class="dif-stat dif-stat--orange">
                <div class="dif-stat__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M3.375 4.5C2.339 4.5 1.5 5.34 1.5 6.375V13.5h12V6.375c0-1.036-.84-1.875-1.875-1.875h-8.25zM13.5 15h-12v2.625c0 1.035.84 1.875 1.875 1.875h.375a3 3 0 116 0h3a.75.75 0 00.75-.75V15z"/><path d="M8.25 19.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0zM15.75 6.75a.75.75 0 00-.75.75v11.25c0 .087.015.17.042.248a3 3 0 015.958.464c.853-.175 1.522-.935 1.464-1.883a18.659 18.659 0 00-3.732-10.104 1.837 1.837 0 00-1.47-.725H15.75z"/><path d="M19.5 19.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0z"/></svg>
                </div>
                <div class="dif-stat__value">100 km</div>
                <p class="dif-stat__label">Recolección y entrega sin costo, con seguro incluido</p>
              </article>

              <article class="dif-stat dif-stat--purple">
                <div class="dif-stat__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg>
                </div>
                <div class="dif-stat__value">Patentado</div>
                <p class="dif-stat__label">Métodos exclusivos — calibramos lo que antes salía del país</p>
              </article>

              <article class="dif-stat dif-stat--teal">
                <div class="dif-stat__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M8.25 10.875a2.625 2.625 0 115.25 0 2.625 2.625 0 01-5.25 0z"/><path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zm-1.125 4.5a4.125 4.125 0 102.338 7.524l2.007 2.006a.75.75 0 101.06-1.06l-2.006-2.007a4.125 4.125 0 00-3.399-6.463z" clip-rule="evenodd"/></svg>
                </div>
                <div class="dif-stat__value">15 unidades</div>
                <p class="dif-stat__label">Flota propia — logística directa sin intermediarios</p>
              </article>

            </div>
          </div>

          <button class="dif-carousel__arrow dif-carousel__arrow--next" aria-label="Siguiente">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 010-1.06z" clip-rule="evenodd"/></svg>
          </button>
        </div>

        <!-- Dots — rendered by JS based on visible count -->
        <div class="dif-carousel__dots" aria-hidden="true"></div>
      </div>
    </section>

    <!-- ══ SECCIÓN 4: CLIENTES ══ -->
    <section class="sectores-marquee" aria-label="Clientes por industria">
      <div class="container">
        <p class="sectores-marquee__label">Empresas líderes que confían en IME</p>
        <div class="ind-nav" id="indNavMarquee" aria-label="Filtrar por industria">
          <div class="ind-nav__track">
            <span class="ind-nav__item">Automotriz</span>
            <span class="ind-nav__item">Alimentaria</span>
            <span class="ind-nav__item">Farmacéutica y Médica</span>
            <span class="ind-nav__item">Energía</span>
            <span class="ind-nav__item">Gobierno y Defensa</span>
          </div>
        </div>
        <div class="logos-marquee" id="logosMarquee" aria-label="Clientes de IME Calibraciones">
          <div class="logos-marquee__track">
            <div class="logos-marquee__set">
              {clientes.map(logo => (
                <div class="logos-marquee__item" data-industry={logo.industry}>
                  <Image src={logo.src} alt={logo.alt} width={200} loading="lazy" format="webp" quality={85} />
                </div>
              ))}
            </div>
            <div class="logos-marquee__set" aria-hidden="true">
              {clientes.map(logo => (
                <div class="logos-marquee__item" data-industry={logo.industry}>
                  <Image src={logo.src} alt={logo.alt} width={200} loading="lazy" format="webp" quality={85} />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ SECCIÓN 5b: VIDEO INSTITUCIONAL ══ -->
    <section class="section video-section" id="video-ime">
      <div class="container">
        <div class="video-section__layout">

          <div class="video-section__media">
            <div class="video-facade" id="videoFacade" data-video-id="I-yKBR_HJ9s" role="button" tabindex="0" aria-label="Reproducir video institucional de IME Calibraciones">
              <img
                class="video-facade__thumb"
                src="https://img.youtube.com/vi/I-yKBR_HJ9s/maxresdefault.jpg"
                alt="Video institucional IME Calibraciones — laboratorio de calibración"
                width="1280" height="720"
                loading="lazy"
              >
              <div class="video-facade__overlay" aria-hidden="true"></div>
              <div class="video-facade__play" aria-hidden="true">
                <div class="video-facade__play-ring"></div>
                <div class="video-facade__play-btn">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 000-1.69L9.54 5.98A.998.998 0 008 6.82z"/>
                  </svg>
                </div>
              </div>
              <div class="video-facade__label" aria-hidden="true">
