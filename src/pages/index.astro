<script>
  // ── Cadena de Valor — carrusel 3 en desktop, 1 en móvil ──────────────────
  (function () {
    const viewport = document.querySelector<HTMLElement>('.cv-viewport')!;
    const track    = document.querySelector<HTMLElement>('.cv-track')!;
    const cards    = Array.from(track.querySelectorAll<HTMLElement>('.cv-card'));
    const prevBtn  = document.querySelector<HTMLButtonElement>('.cv-arrow--prev')!;
    const nextBtn  = document.querySelector<HTMLButtonElement>('.cv-arrow--next')!;
    const dotsWrap = document.querySelector<HTMLElement>('.cv-dots')!;

    const GAP   = 20;
    const TOTAL = cards.length;
    let current = 0;

    function vis() {
      const w = window.innerWidth;
      if (w >= 1024) return 3;
      if (w >= 600)  return 2;
      return 1;
    }

    function maxIdx() { return TOTAL - vis(); }

    function layout() {
      const v    = vis();
      const cardW = (viewport.offsetWidth - GAP * (v - 1)) / v;
      cards.forEach(c => { c.style.width = cardW + 'px'; });
      current = Math.min(current, maxIdx());
      buildDots();
      move(false);
      updateButtons();
    }

    function move(animate: boolean) {
      const cardW = cards[0].offsetWidth;
      track.style.transition = animate ? 'transform .35s ease' : 'none';
      track.style.transform  = `translateX(-${current * (cardW + GAP)}px)`;
    }

    function buildDots() {
      dotsWrap.innerHTML = '';
      for (let i = 0; i <= maxIdx(); i++) {
        const d = document.createElement('button');
        d.className = 'cv-dot' + (i === current ? ' cv-dot--active' : '');
        d.setAttribute('aria-label', `Paso ${i + 1}`);
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
      }
    }

    function updateDots() {
      dotsWrap.querySelectorAll('.cv-dot').forEach((d, i) =>
        d.classList.toggle('cv-dot--active', i === current));
    }

    function updateButtons() {
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= maxIdx();
    }

    function goTo(i: number) {
      current = Math.max(0, Math.min(i, maxIdx()));
      move(true);
      updateDots();
      updateButtons();
    }

    // Auto-avance
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function startAuto() {
      autoTimer = setInterval(() => goTo(current >= maxIdx() ? 0 : current + 1), 4000);
    }
    function stopAuto() {
      if (autoTimer !== null) { clearInterval(autoTimer); autoTimer = null; }
    }

    prevBtn.addEventListener('click', () => { goTo(current - 1); stopAuto(); startAuto(); });
    nextBtn.addEventListener('click', () => { goTo(current + 1); stopAuto(); startAuto(); });

    // Pausa al hacer hover
    viewport.addEventListener('mouseenter', stopAuto);
    viewport.addEventListener('mouseleave', startAuto);

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(layout, 120);
    });

    layout();
    startAuto();
  })();
</script>

