<script>
  // ── Diferenciadores carousel ──────────────────────────────────────────────
  (function () {
    const track    = document.querySelector<HTMLElement>('.dif-carousel__track')!;
    const viewport = document.querySelector<HTMLElement>('.dif-carousel__viewport')!;
    const prevBtn  = document.querySelector<HTMLButtonElement>('.dif-carousel__arrow--prev')!;
    const nextBtn  = document.querySelector<HTMLButtonElement>('.dif-carousel__arrow--next')!;
    const dotsWrap = document.querySelector<HTMLElement>('.dif-carousel__dots')!;
    const cards    = Array.from(track.querySelectorAll<HTMLElement>('.dif-stat'));

    const GAP   = 16;
    const TOTAL = cards.length;
    const MIN_CARD = 200; // minimum readable card width in px
    let current = 0;
    let vw = 0; // set by ResizeObserver — always accurate

    function visibleCount() {
      if (vw >= MIN_CARD * 3 + GAP * 2) return 3;
      if (vw >= MIN_CARD * 2 + GAP)     return 2;
      return 1;
    }

    function maxIndex() { return TOTAL - visibleCount(); }

    function setWidths() {
      const vis   = visibleCount();
      const cardW = (vw - GAP * (vis - 1)) / vis;
      cards.forEach(c => { c.style.flex = `0 0 ${cardW}px`; });
      return cardW;
    }

    function renderDots() {
      dotsWrap.innerHTML = '';
      for (let i = 0; i <= maxIndex(); i++) {
        const d = document.createElement('span');
        d.className = 'dif-carousel__dot' + (i === current ? ' dif-carousel__dot--active' : '');
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
      }
    }

    function updateDots() {
      dotsWrap.querySelectorAll('.dif-carousel__dot').forEach((d, i) =>
        d.classList.toggle('dif-carousel__dot--active', i === current));
    }

    function updateCenter() {
      const vis = visibleCount();
      cards.forEach((c, i) => {
        const isCenter = vis === 3
          ? i === current + 1
          : (i >= current && i < current + vis);
        c.classList.toggle('dif-stat--center', isCenter);
      });
    }

    function goTo(index: number) {
      const cardW = setWidths();
      current = Math.max(0, Math.min(index, maxIndex()));
      track.style.transform = `translateX(-${current * (cardW + GAP)}px)`;
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= maxIndex();
      updateDots();
      updateCenter();
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    // ResizeObserver fires with the real element size — no window.innerWidth guessing
    new ResizeObserver(entries => {
      const newVw = entries[0].contentRect.width;
      if (newVw === vw) return;
      vw = newVw;
      current = Math.min(current, maxIndex());
      renderDots();
      goTo(current);
    }).observe(viewport);
  })();
</script>
