---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import { clientes } from '../data/clientes';
import slide1 from '../assets/images/hero/slide-1.png';
import slide2 from '../assets/images/hero/slide-2.png';
import slide3 from '../assets/images/hero/slide-3.png';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="IME Calibraciones — Laboratorio Acreditado en Tlaxcala, México"
  description="Calibración acreditada de instrumentos de medición. Trazabilidad nacional e internacional. Servicio para industria manufacturera, farmacéutica y automotriz en México."
>

  <!-- Preload del video hero para mejorar LCP -->
  <link rel="preload" as="video" href={`${b}/assets/video/hero-lab.mp4`} type="video/mp4" slot="head">

  <!-- Schema JSON-LD específico del home -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://imecalibraciones.com/#organization",
        "name": "IME Calibraciones",
        "legalName": "Ingeniería y Metrología Certificada Para Calibración de Equipos de Control y Pruebas S.A. de C.V.",
        "url": "https://imecalibraciones.com",
        "logo": "https://imecalibraciones.com/assets/images/logo/logo-ime.svg",
        "telephone": "+522461261782",
        "email": "contacto@imecalibraciones.com",
        "sameAs": [
          "https://www.facebook.com/CalibracionIME",
          "https://www.instagram.com/calibracionesime/",
          "https://www.youtube.com/@CalibracionesIME",
          "https://mx.linkedin.com/company/calibracionesime"
        ]
      },
      {
        "@type": "LocalBusiness",
        "@id": "https://imecalibraciones.com/#localbusiness",
        "name": "IME Calibraciones",
        "description": "Laboratorio de calibración acreditado por EMA bajo ISO/IEC 17025.",
        "telephone": "+522461261782",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Tlaxcala",
          "addressRegion": "Tlaxcala",
          "addressCountry": "MX"
        },
        "url": "https://imecalibraciones.com",
        "priceRange": "$$"
      },
      {
        "@type": "WebSite",
        "@id": "https://imecalibraciones.com/#website",
        "url": "https://imecalibraciones.com",
        "name": "IME Calibraciones",
        "publisher": { "@id": "https://imecalibraciones.com/#organization" }
      }
    ]
  }
  </script>

  <main>

    <!-- ══ SECCIÓN 1: HERO ══ -->
    <section class="hero" id="hero" aria-label="Presentación IME Calibraciones">

      <button class="hero__nav hero__nav--prev" aria-label="Diapositiva anterior">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 010 1.06L8.06 10l3.72 3.72a.75.75 0 11-1.06 1.06l-4.25-4.25a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 0z" clip-rule="evenodd"/></svg>
      </button>
      <button class="hero__nav hero__nav--next" aria-label="Siguiente diapositiva">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 010-1.06z" clip-rule="evenodd"/></svg>
      </button>

      <div class="hero__bg" aria-hidden="true">
        <div class="hero__carousel" id="heroCarousel">
          <div class="hero__slide hero__slide--video hero__slide--active">
            <video autoplay muted loop playsinline poster={`${b}/assets/images/hero/hero-poster.png`} fetchpriority="high">
              <source src={`${b}/assets/video/hero-lab.mp4`} type="video/mp4">
            </video>
          </div>
          <div class="hero__slide">
            <Image src={slide1} alt="Laboratorio de calibración IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="eager" format="webp" quality={80} />
          </div>
          <div class="hero__slide">
            <Image src={slide2} alt="Instrumentos de medición calibrados por IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="lazy" format="webp" quality={80} />
          </div>
          <div class="hero__slide">
            <Image src={slide3} alt="Equipo de metrólogos certificados IME" widths={[640,1024,1280,1920]} sizes="100vw" loading="lazy" format="webp" quality={80} />
          </div>
        </div>
        <div class="hero__overlay"></div>
        <div class="hero__bg-pattern"></div>
      </div>

      <div class="container">
        <div class="hero__content">
          <div class="hero__badges" aria-label="Acreditaciones">
            <a href={`${b}/acreditaciones/#panel-ema`} class="hero__badge">
              <svg class="hero__badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
              </svg>
              <span>EMA</span>
            </a>
            <a href={`${b}/acreditaciones/#panel-pjla`} class="hero__badge">
              <svg class="hero__badge-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.491 4.491 0 01-3.497-1.307 4.491 4.491 0 01-1.307-3.497A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
              </svg>
              <span>PJLA</span>
            </a>
          </div>

          <div class="hero__text">
            <h1 class="hero__title hero__title--long" id="heroTitle">
              IME<br>
              <span class="hero__title-highlight">CERTIFICADA</span>
            </h1>

            <p class="hero__subtitle" id="heroSubtitle">
              Ingeniería y Metrología Certificada para Equipos de Control y Pruebas S.A. de C.V.
            </p>
          </div>

          <div class="hero__actions">
            <a href={`https://wa.me/522461261782?text=${encodeURIComponent('Hola IME, vengo del banner principal de su sitio web y me gustaría solicitar una cotización para sus servicios de calibración. ¿Podrían ayudarme?')}`} class="btn btn-primary btn-lg hero__cta-primary" target="_blank" rel="noopener">
              Solicitar cotización
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
              </svg>
            </a>
            <a href={`${b}/catalogo/`} class="btn btn-outline-white btn-lg">Ver catálogo de calibraciones</a>
          </div>
        </div>
      </div>

      <!-- Progress bars estilo Instagram -->
      <div class="hero__progress-bars" aria-hidden="true">
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
        <div class="hero__progress-bar"><div class="hero__progress-fill"></div></div>
      </div>

      <div class="hero__trust" aria-label="Indicadores clave">
        <ul class="hero__stats" role="list">
          <li class="hero__stat">
            <a href={`${b}/nosotros/`} class="hero__stat-link">
              <strong class="hero__stat-value">
                <span class="counter" data-target="30" data-suffix="+">30+</span>
              </strong>
              <span class="hero__stat-label">Años de<br>experiencia</span>
            </a>
          </li>
          <li class="hero__stat">
            <a href={`${b}/catalogo/?acreditacion=PJLA`} class="hero__stat-link">
              <strong class="hero__stat-value">
                <span class="counter" data-target="32">32</span>
              </strong>
              <span class="hero__stat-label">Magnitudes acreditadas<br>ante PJLA</span>
            </a>
          </li>
          <li class="hero__stat">
            <a href={`${b}/catalogo/?acreditacion=EMA`} class="hero__stat-link">
              <strong class="hero__stat-value">
                <span class="counter" data-target="7">7</span>
              </strong>
              <span class="hero__stat-label">Magnitudes acreditadas<br>ante EMA</span>
            </a>
          </li>
          <li class="hero__stat">
            <a href={`${b}/acreditaciones/`} class="hero__stat-link">
              <strong class="hero__stat-value hero__stat-value--text">ISO/IEC 17025</strong>
              <span class="hero__stat-label">Norma de<br>acreditación vigente</span>
            </a>
          </li>
        </ul>
      </div>

      <div class="hero__scroll-hint" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>

      <!-- Tira de magnitudes -->
      <div class="magnitudes-strip" id="magnitudes" aria-label="Magnitudes de calibración">
        <div class="magnitudes-strip__track-wrap" aria-hidden="true">
          <ul class="magnitudes-strip__track" role="list">
            {(m => [...m, ...m])(['Eléctrica','Presión','Temperatura termodinámica','%H.R.','Óptica','Turbidez','Tiempo','Acústica','Masa','Fuerza','Tensión','Velocidad del aire','Velocidad Lineal','Tensión Superficial','Torque','Dureza','Volumen','Densidad','Concentración de Alcohol','Vibración','Flujo','Viscosidad','pH','Conductividad','Cloro','Oxígeno Disuelto','Dimensional','Mediciones especiales','%Humedad','Frecuencia','Coeficiente de Fricción','Ondas de Radio']).map((m, i) => (
              <li aria-hidden={i >= 32 ? 'true' : undefined}>
                <span class="magnitudes-strip__dot"></span>{m}
              </li>
            ))}
          </ul>
        </div>
        <p class="sr-only">IME Calibraciones calibra 32 magnitudes: Eléctrica, Presión, Temperatura termodinámica, %H.R., Óptica, Turbidez, Tiempo, Acústica, Masa, Fuerza, Tensión, Velocidad del aire, Velocidad Lineal, Tensión Superficial, Torque, Dureza, Volumen, Densidad, Concentración de Alcohol, Vibración, Flujo, Viscosidad, pH, Conductividad, Cloro, Oxígeno Disuelto, Dimensional, Mediciones especiales, %Humedad, Frecuencia, Coeficiente de Fricción y Ondas de Radio.</p>
      </div>

    </section>

    <!-- ══ SECCIÓN 3: CADENA DE VALOR ══ -->
    <section class="cv-section" id="cadena-valor">
      <div class="container">
        <div class="section__header text-center">
          <p class="section__eyebrow">Por qué elegirnos</p>
          <h2 class="section-title">Cadena de Valor</h2>
        </div>
        <div class="cv-carousel">
          <button class="cv-arrow cv-arrow--prev" aria-label="Anterior" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 010 1.06L8.06 10l3.72 3.72a.75.75 0 11-1.06 1.06l-4.25-4.25a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 0z" clip-rule="evenodd"/></svg>
          </button>
          <div class="cv-viewport">
            <div class="cv-track">

              <article class="cv-card">
                <div class="cv-card__body">
                                    <h3 class="cv-card__title">Levantamiento</h3>
                  <p class="cv-card__desc">Asistimos a planta a realizar el levantamiento de tus equipos, asegurando información clara y guía metrológica de tu calibración.</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 10V5a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v5" /><path d="M14 6a6 6 0 0 1 6 6v3" /><path d="M4 15v-3a6 6 0 0 1 6 -6" /><rect x="2" y="15" width="20" height="4" rx="1" /><path d="M10 19v4" /><path d="M14 19v4" /></svg>
                </div>
              </article>

              <article class="cv-card">
                <div class="cv-card__body">

                  <h3 class="cv-card__title">Técnicos Signatarios Acreditados</h3>
                  <p class="cv-card__desc">No solo calibramos, te acompañamos antes, durante y después del servicio con asesoría técnica sin costo.</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 15a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" /><path d="M13 17.5v4.5l2 -1.5l2 1.5v-4.5" /><path d="M10 19h-5a2 2 0 0 1 -2 -2v-10c0 -1.1 .9 -2 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -1 1.73" /><path d="M6 9l12 0" /><path d="M6 12l3 0" /><path d="M6 15l2 0" /></svg>
                </div>
              </article>

              <article class="cv-card">
                <div class="cv-card__body">

                  <h3 class="cv-card__title">Recolección y Entrega</h3>
                  <p class="cv-card__desc">Sin costo adicional en un radio de 100 km de IME Certificada, o bien calibración en sitio si lo necesitas.</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 17a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M15 17a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M5 17h-2v-4m-1 -8h11v12m-4 0h6m4 0h2v-6h-8m0 -5h5l3 5" /><path d="M3 9l4 0" /></svg>
                </div>
              </article>

              <article class="cv-card">
                <div class="cv-card__body">

                  <h3 class="cv-card__title">Programa de Recalibración</h3>
                  <p class="cv-card__desc">Evitas olvidos y mantienes el control de tus equipos. ¡Nosotros te avisamos!</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11.795 21h-6.795a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v4" /><path d="M18 14v4h4" /><path d="M14 18a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M15 3v4" /><path d="M7 3v4" /><path d="M3 11h16" /></svg>
                </div>
              </article>

              <article class="cv-card">
                <div class="cv-card__body">

                  <h3 class="cv-card__title">Conformidad en Auditorías</h3>
                  <p class="cv-card__desc">Te ayudamos a estar listo para auditorías con informes claros, trazables y alineados a normativas.</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2" /><path d="M9 15l2 2l4 -4" /></svg>
                </div>
              </article>

              <article class="cv-card">
                <div class="cv-card__body">

                  <h3 class="cv-card__title">Seguridad de tus Equipos</h3>
                  <p class="cv-card__desc">Tus equipos están protegidos con seguro durante el traslado. Cobertura ante siniestros garantizada.</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11.46 20.846a12 12 0 0 1 -7.96 -14.846a12 12 0 0 0 8.5 -3a12 12 0 0 0 8.5 3a12 12 0 0 1 -.09 7.06" /><path d="M15 19l2 2l4 -4" /></svg>
                </div>
              </article>

              <article class="cv-card">
                <div class="cv-card__body">

                  <h3 class="cv-card__title">Cursos Gratuitos</h3>
                  <p class="cv-card__desc">2 cursos gratuitos para mejorar el uso e interpretación de resultados de calibración.</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 9l-10 -4l-10 4l10 4l10 -4v6" /><path d="M6 10.6v5.4a6 3 0 0 0 12 0v-5.4" /></svg>
                </div>
              </article>

              <article class="cv-card">
                <div class="cv-card__body">

                  <h3 class="cv-card__title">Urgencia</h3>
                  <p class="cv-card__desc">Servicio de urgencia con entrega en 3 días. Tus informes disponibles en plataforma para descargar cuando los necesites.</p>
                  <svg class="cv-card__bg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" /><path d="M12 7v5l3 3" /></svg>
                </div>
              </article>

            </div>
          </div>
          <button class="cv-arrow cv-arrow--next" aria-label="Siguiente">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 010-1.06z" clip-rule="evenodd"/></svg>
          </button>
        </div>
        <div class="cv-dots"></div>
      </div>
    </section>

    <!-- ══ SECCIÓN 4: CLIENTES ══ -->
    <section class="sectores-marquee" aria-label="Clientes por industria">
      <div class="container">
        <p class="sectores-marquee__label">Empresas líderes que confían en IME</p>
        <div class="ind-nav" id="indNavMarquee" aria-label="Filtrar por industria">
          <div class="ind-nav__track">
            <span class="ind-nav__item">Automotriz</span>
            <span class="ind-nav__item">Alimentaria</span>
            <span class="ind-nav__item">Farmacéutica y Médica</span>
            <span class="ind-nav__item">Energía</span>
            <span class="ind-nav__item">Gobierno y Defensa</span>
          </div>
        </div>
        <div class="logos-marquee" id="logosMarquee" aria-label="Clientes de IME Calibraciones">
          <div class="logos-marquee__track">
            <div class="logos-marquee__set">
              {clientes.map(logo => (
                <div class="logos-marquee__item" data-industry={logo.industry}>
                  <Image src={logo.src} alt={logo.alt} width={200} loading="lazy" format="webp" quality={85} />
                </div>
              ))}
            </div>
            <div class="logos-marquee__set" aria-hidden="true">
              {clientes.map(logo => (
                <div class="logos-marquee__item" data-industry={logo.industry}>
                  <Image src={logo.src} alt={logo.alt} width={200} loading="lazy" format="webp" quality={85} />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ SECCIÓN 5b: VIDEO INSTITUCIONAL ══ -->
    <section class="section video-section" id="video-ime">
      <div class="container">
        <div class="video-section__layout">

          <div class="video-section__media">
            <div class="video-facade" id="videoFacade" data-video-id="I-yKBR_HJ9s" role="button" tabindex="0" aria-label="Reproducir video institucional de IME Calibraciones">
              <img
                class="video-facade__thumb"
                src="https://img.youtube.com/vi/I-yKBR_HJ9s/maxresdefault.jpg"
                alt="Video institucional IME Calibraciones — laboratorio de calibración"
                width="1280" height="720"
                loading="lazy"
              >
              <div class="video-facade__overlay" aria-hidden="true"></div>
              <div class="video-facade__play" aria-hidden="true">
                <!-- Botón oficial de YouTube -->
                <svg class="video-facade__yt-btn" viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
                  <path d="M66.52 7.74a8.55 8.55 0 00-6.01-6.07C55.79.13 34 0 34 0S12.21.13 7.49 1.67A8.55 8.55 0 001.48 7.74C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26a8.55 8.55 0 006.01 6.07C12.21 47.87 34 48 34 48s21.79-.13 26.51-1.67a8.55 8.55 0 006.01-6.07C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#ff0000"/>
                  <path d="M27 34l18-10-18-10z" fill="#fff"/>
                </svg>
              </div>
            </div>
          </div>

          <div class="video-section__content animate-on-scroll">
            <p class="section__eyebrow">Conózcanos</p>
            <h2 class="section-title" style="text-align:left">Conoce nuestra trayectoria</h2>
