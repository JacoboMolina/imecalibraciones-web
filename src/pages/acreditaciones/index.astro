---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { Image } from 'astro:assets';
import logoEma from '../../assets/images/acreditaciones/logo-ema.png';
import logoPjla from '../../assets/images/acreditaciones/logo-pjla.jpg';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Acreditaciones — IME Calibraciones | EMA · PJLA ISO/IEC 17025"
  description="Laboratorio de calibración con doble acreditación: EMA (México) y PJLA No. 54194 (EUA) bajo ISO/IEC 17025. Trazabilidad a CENAM y NIST."
>
  <script type="application/ld+json" slot="head">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "IME Calibraciones",
    "url": "https://imecalibraciones.com",
    "hasCredential": [
      {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "Acreditación",
        "name": "Acreditación EMA ISO/IEC 17025",
        "recognizedBy": { "@type": "Organization", "name": "Entidad Mexicana de Acreditación (EMA)", "url": "https://www.ema.org.mx" }
      },
      {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "Acreditación",
        "name": "Acreditación PJLA No. 54194 ISO/IEC 17025",
        "recognizedBy": { "@type": "Organization", "name": "Perry Johnson Laboratory Accreditation (PJLA)", "url": "https://www.pjlabs.com" }
      }
    ]
  })}</script>

  <main>

    <!-- ===== PAGE HEADER COMPACTO ===== -->
    <PageHeader
      label="Acreditaciones IME Calibraciones"
      breadcrumb={[{ label: 'Inicio', href: `${b}/` }, { label: 'Acreditaciones' }]}
      title="Doble Acreditación"
      titleAccent="Internacional"
      subtitle="El único laboratorio en México con acreditación simultánea ante EMA y PJLA bajo ISO/IEC 17025. Validez nacional e internacional en cada certificado."
      anchors={[
        { label: 'Acreditación EMA',  href: '#panel-ema'  },
        { label: 'Acreditación PJLA', href: '#panel-pjla' },
      ]}
    />

    <!-- ===== CERTIFICADOS ===== -->
    <section class="section acred-certs">
      <div class="container">

        <div class="acred-grid">

          <!-- EMA -->
          <div class="acred-card" id="panel-ema">
            <div class="acred-card__top">
              <div class="acred-card__seal">
                <Image src={logoEma} alt="EMA — Entidad Mexicana de Acreditación" loading="lazy" format="webp" quality={85} />
              </div>
              <div class="acred-card__heading">
                <h2>Acreditación EMA</h2>
                <p>Entidad Mexicana de Acreditación</p>
              </div>
              <a href={`${b}/assets/pdfs/acreditacion-ema.pdf`} class="acred-card__download" download aria-label="Descargar certificado EMA">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z"/><path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z"/></svg>
                Descargar PDF
              </a>
            </div>
            <div class="acred-card__chips">
              <span class="chip chip--blue">ISO/IEC 17025:2017</span>
              <span class="chip chip--green">7 magnitudes</span>
              <span class="chip chip--gray">Alcance Nacional</span>
              <span class="chip chip--gray">Vigente</span>
            </div>
            <div class="acred-cert-details">
              <div class="acred-cert-details__codes">
                <p class="acred-cert-details__label">Números de acreditación</p>
                <div class="acred-cert-details__chips">
                  <span class="chip chip--blue">H-79</span>
                  <span class="chip chip--blue">M-245</span>
                  <span class="chip chip--blue">ME-29</span>
                  <span class="chip chip--blue">E-167</span>
                  <span class="chip chip--blue">P-192</span>
                  <span class="chip chip--blue">T-171</span>
                  <span class="chip chip--blue">V-103</span>
                </div>
              </div>
              <div class="acred-cert-details__why">
                <h4>¿Por qué calibrar con un Laboratorio Acreditado ante EMA?</h4>
                <p>Bajo la Ley de Infraestructura de la Calidad, se entiende que acreditación es el reconocimiento emitido por una Entidad de Acreditación por la cual se reconoce la competencia técnica y confiabilidad de las entidades para operar como Organismos de Evaluación de la Conformidad.</p>
              </div>
            </div>
            <div class="acred-card__viewer">
              <iframe
                src={`${b}/assets/pdfs/acreditacion-ema.pdf#zoom=page-width&toolbar=0`}
                title="Certificado EMA — IME Calibraciones"
                loading="lazy">
                <p>Tu navegador no puede mostrar PDFs. <a href={`${b}/assets/pdfs/acreditacion-ema.pdf`} download>Descarga el certificado aquí</a>.</p>
              </iframe>
            </div>
          </div>

          <!-- PJLA -->
          <div class="acred-card acred-card--pjla" id="panel-pjla">
            <div class="acred-card__top">
              <div class="acred-card__seal acred-card__seal--pjla">
                <Image src={logoPjla} alt="PJLA — Perry Johnson Laboratory Accreditation" loading="lazy" format="webp" quality={85} />
              </div>
              <div class="acred-card__heading">
                <h2>Acreditación PJLA</h2>
                <p>Perry Johnson Laboratory Accreditation · No. 54194</p>
              </div>
              <a href={`${b}/assets/pdfs/acreditacion-pjla.pdf`} class="acred-card__download" download aria-label="Descargar certificado PJLA">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z"/><path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z"/></svg>
                Descargar PDF
              </a>
            </div>
            <div class="acred-card__chips">
              <span class="chip chip--purple">ISO/IEC 17025:2017</span>
              <span class="chip chip--green">No. 54194</span>
              <span class="chip chip--gray">ILAC / MRA</span>
              <span class="chip chip--gray">+100 países</span>
            </div>
            <div class="acred-cert-details acred-cert-details--pjla">
              <div class="acred-cert-details__codes">
                <p class="acred-cert-details__label">Número de acreditación</p>
                <div class="acred-cert-details__chips">
                  <span class="chip chip--purple">54194</span>
                </div>
              </div>
              <div class="acred-cert-details__why">
                <h4>¿Por qué calibrar con un Laboratorio Acreditado ante PJLA?</h4>
                <p>IME proporciona servicios de calibración en 32 magnitudes acreditadas y equipos trazables ante el SI, bajo la norma ISO/IEC 17025:2017 y su equivalente en Norma Mexicana NMX-EC-17025-IMNC-2018.</p>
              </div>
            </div>
            <div class="acred-card__viewer">
              <iframe
                src={`${b}/assets/pdfs/acreditacion-pjla.pdf#zoom=page-width&toolbar=0`}
                title="Certificado PJLA No. 54194 — IME Calibraciones"
                loading="lazy">
                <p>Tu navegador no puede mostrar PDFs. <a href={`${b}/assets/pdfs/acreditacion-pjla.pdf`} download>Descarga el certificado aquí</a>.</p>
              </iframe>
            </div>
          </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== TRAZABILIDAD ===== -->
    <section class="section section--alt">
      <div class="container">
        <header class="section__header text-center">
          <p class="section__eyebrow">Cadena de trazabilidad</p>
          <h2 class="section-title">Trazabilidad Metrológica</h2>
          <p class="section__subtitle text-muted">Nuestros patrones están calibrados y trazados a los institutos nacionales e internacionales de metrología.</p>
        </header>
        <div class="trazabilidad-chain">
          <div class="trazabilidad-level">
            <span class="trazabilidad-level__label">Internacional</span>
            <div class="trazabilidad-level__items">
              <div class="trazabilidad-item">
                <strong>NIST</strong>
                <span>National Institute of Standards and Technology (EUA)</span>
              </div>
              <div class="trazabilidad-item">
                <strong>BIPM</strong>
                <span>Bureau International des Poids et Mesures</span>
              </div>
            </div>
          </div>
          <div class="trazabilidad-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12 2.25a.75.75 0 01.75.75v16.19l6.22-6.22a.75.75 0 111.06 1.06l-7.5 7.5a.75.75 0 01-1.06 0l-7.5-7.5a.75.75 0 111.06-1.06l6.22 6.22V3a.75.75 0 01.75-.75z" clip-rule="evenodd"/></svg>
          </div>
          <div class="trazabilidad-level">
            <span class="trazabilidad-level__label">Nacional</span>
            <div class="trazabilidad-level__items">
              <div class="trazabilidad-item">
                <strong>CENAM</strong>
                <span>Centro Nacional de Metrología (México)</span>
              </div>
            </div>
          </div>
          <div class="trazabilidad-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12 2.25a.75.75 0 01.75.75v16.19l6.22-6.22a.75.75 0 111.06 1.06l-7.5 7.5a.75.75 0 01-1.06 0l-7.5-7.5a.75.75 0 111.06-1.06l6.22 6.22V3a.75.75 0 01.75-.75z" clip-rule="evenodd"/></svg>
          </div>
          <div class="trazabilidad-level trazabilidad-level--ime">
            <span class="trazabilidad-level__label">IME Calibraciones</span>
            <div class="trazabilidad-level__items">
              <div class="trazabilidad-item">
                <strong>Laboratorio acreditado EMA · PJLA</strong>
                <span>Tlaxcala, México · 32 magnitudes</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== LO QUE TIENES QUE SABER ===== -->
    <section class="section">
      <div class="container">
        <header class="section__header text-center">
          <p class="section__eyebrow">Valor para su empresa</p>
          <h2 class="section-title">Lo que tienes que saber</h2>
        </header>
        <div class="acred-benefits">
          <div class="acred-benefit">
            <div class="acred-benefit__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/></svg>
            </div>
            <h3>Cumplimiento normativo</h3>
            <p>Certificados reconocidos por auditores ISO, reguladores y clientes nacionales e internacionales.</p>
          </div>
          <div class="acred-benefit">
            <div class="acred-benefit__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.375 2.25c-1.035 0-1.875.84-1.875 1.875v15.75c0 1.035.84 1.875 1.875 1.875h.75c1.035 0 1.875-.84 1.875-1.875V4.125c0-1.036-.84-1.875-1.875-1.875h-.75zM9.75 8.625c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-.75a1.875 1.875 0 01-1.875-1.875V8.625zM3 13.125c0-1.036.84-1.875 1.875-1.875h.75c1.036 0 1.875.84 1.875 1.875v6.75c0 1.035-.84 1.875-1.875 1.875h-.75A1.875 1.875 0 013 19.875v-6.75z"/></svg>
            </div>
            <h3>Decisiones con datos confiables</h3>
            <p>Una calibración trazable reduce rechazos, desperdicios y costos por no conformidades.</p>
          </div>
          <div class="acred-benefit">
            <div class="acred-benefit__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM6.262 6.072a8.25 8.25 0 1010.562-.766 4.5 4.5 0 01-1.318 1.357L14.25 7.5l.165.33a.809.809 0 01-1.086 1.085l-.604-.302a1.125 1.125 0 00-1.298.21l-.132.131c-.439.44-.439 1.152 0 1.591l.296.296c.256.257.622.374.98.314l1.17-.195c.323-.054.654.036.905.245l1.33 1.108c.32.267.46.694.358 1.1a8.7 8.7 0 01-2.288 4.04l-.723.724a1.125 1.125 0 01-1.298.21l-.153-.076a1.125 1.125 0 01-.622-1.006v-1.089c0-.298-.119-.585-.33-.796l-1.347-1.347a1.125 1.125 0 01-.21-1.298L9.75 12l-1.64-1.64a6 6 0 01-1.676-3.257l-.172-1.03z" clip-rule="evenodd"/></svg>
            </div>
            <h3>Validez internacional</h3>
            <p>La acreditación PJLA bajo ILAC/MRA garantiza el reconocimiento de sus mediciones en más de 100 países.</p>
          </div>
          <div class="acred-benefit">
            <div class="acred-benefit__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M11.99 2.243a4.49 4.49 0 00-3.398 1.55 4.49 4.49 0 00-3.497 1.306 4.491 4.491 0 00-1.306 3.497 4.49 4.49 0 00-1.55 3.397c0 1.357.601 2.573 1.55 3.397a4.491 4.491 0 001.306 3.497 4.49 4.49 0 003.497 1.307 4.49 4.49 0 003.397 1.549 4.49 4.49 0 003.397-1.549 4.49 4.49 0 003.497-1.307 4.491 4.491 0 001.306-3.497 4.49 4.49 0 001.55-3.397 4.49 4.49 0 00-1.55-3.397 4.491 4.491 0 00-1.306-3.497 4.49 4.49 0 00-3.497-1.306 4.49 4.49 0 00-3.398-1.55zm3.11 7.858a.75.75 0 10-1.22-.872l-3.236 4.53-1.643-1.643a.75.75 0 10-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.77-5.25-.001-.001z" clip-rule="evenodd"/></svg>
            </div>
            <h3>Incertidumbre declarada</h3>
            <p>Cada certificado incluye la incertidumbre calculada conforme a la GUM, esencial para análisis de capabilidad y SPC.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="section section--cta">
      <div class="container container--narrow text-center">
        <h2>Más que un servicio de calibración</h2>
        <p>Ofrecemos respaldo para que tus mediciones sean confiables y tus procesos cumplan ante auditorías.</p>
        <div class="cta-actions">
          <a href={`${b}/contacto/`} class="btn btn-primary">Solicita tu calibración acreditada</a>
          <a href={`${b}/servicios/`} class="btn btn-secondary">Ver servicios</a>
        </div>
      </div>
    </section>

  </main>


</Base>

<style>
/* ── HERO ── */
.acred-hero {
  background: linear-gradient(135deg, #041a39 0%, #063d73 100%);
  padding: var(--space-10) 0 var(--space-12);
  position: relative;
  overflow: hidden;
}
.acred-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}

.acred-hero__breadcrumb { padding-bottom: var(--space-6); }
.acred-hero__breadcrumb :global(ol) { color: rgba(255,255,255,.5); }
.acred-hero__breadcrumb :global(a) { color: rgba(255,255,255,.65); }
.acred-hero__breadcrumb :global(li[aria-current="page"]) { color: rgba(255,255,255,.9); }

.acred-hero__body {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: var(--space-10);
  align-items: center;
  position: relative;
}

.acred-hero__eyebrow {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #c8a840;
  margin-bottom: var(--space-3);
}
.acred-hero__title {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 800;
  color: #fff;
  line-height: 1.15;
  margin-bottom: var(--space-4);
  letter-spacing: -.02em;
}
.acred-hero__subtitle {
  font-size: var(--text-base);
  color: rgba(255,255,255,.7);
  line-height: 1.7;
  max-width: 520px;
  margin: 0;
}
.acred-hero__subtitle strong { color: #fff; }

.acred-hero__badges {
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: center;
}
.acred-hero__badge {
  display: flex;
  align-items: center;
  gap: 14px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.15);
  border-radius: 14px;
  padding: 14px 18px;
  backdrop-filter: blur(8px);
  width: 280px;
}
.acred-hero__badge-seal {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: linear-gradient(135deg, #c8a840, #f0d060);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(200,168,64,.35);
}
.acred-hero__badge-seal--pjla {
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  box-shadow: 0 4px 12px rgba(124,58,237,.35);
}
.acred-hero__badge-seal svg { width: 24px; height: 24px; color: #fff; }
.acred-hero__badge-info { display: flex; flex-direction: column; gap: 2px; }
.acred-hero__badge-info strong { font-size: .9375rem; font-weight: 700; color: #fff; }
.acred-hero__badge-info span { font-size: .75rem; color: rgba(255,255,255,.6); }
.acred-hero__badge-scope {
  display: inline-block;
  font-size: .6875rem !important;
  font-weight: 600;
  color: #c8a840 !important;
  letter-spacing: .04em;
}
.acred-hero__badge-divider {
  font-size: 1.25rem;
  font-weight: 800;
  color: rgba(255,255,255,.3);
}

/* ── CERT CARDS ── */
.acred-certs { padding-top: var(--space-10); }
.acred-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-8);
  align-items: start;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
}

.acred-card {
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-line);
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(4,26,57,.07);
  background: #fff;
  border-top: 3px solid var(--color-primary);
}
.acred-card--pjla { border-top-color: #7c3aed; }

.acred-card__top {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-5) var(--space-6);
  border-bottom: 1px solid var(--color-line);
  flex-wrap: wrap;
}
.acred-card__seal {
  height: 48px;
  width: auto;
  min-width: 56px;
  max-width: 110px;
  border-radius: 8px;
  background: #fff;
  border: 1px solid var(--color-line);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  padding: 5px 10px;
  overflow: hidden;
}
.acred-card__seal img { width: 100%; height: 100%; object-fit: contain; display: block; }

.acred-card__heading { flex: 1; min-width: 0; }
.acred-card__heading h2 {
  font-size: 1.0625rem;
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 2px;
}
.acred-card__heading p {
  font-size: .8125rem;
  color: var(--color-muted);
  margin: 0;
}

.acred-card__download {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: .8125rem;
  font-weight: 600;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  padding: 6px 12px;
  border-radius: var(--radius-md);
  text-decoration: none;
  white-space: nowrap;
  transition: background .15s, color .15s;
  flex-shrink: 0;
}
.acred-card--pjla .acred-card__download { color: #7c3aed; border-color: #7c3aed; }
.acred-card__download:hover { background: var(--color-primary); color: #fff; }
.acred-card--pjla .acred-card__download:hover { background: #7c3aed; color: #fff; }

.acred-card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: var(--space-3) var(--space-6);
  border-bottom: 1px solid var(--color-line);
  background: var(--color-surface-1, #f8fafc);
}
.chip {
  display: inline-flex;
  align-items: center;
  font-size: .6875rem;
  font-weight: 600;
  letter-spacing: .04em;
