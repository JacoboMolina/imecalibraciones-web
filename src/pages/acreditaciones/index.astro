<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.acred-tab');

  function activateTab(tabId: string) {
    tabs.forEach(t => {
      const isTarget = t.dataset.tab === tabId;
      t.classList.toggle('acred-tab--active', isTarget);
      t.setAttribute('aria-selected', String(isTarget));
    });
    document.querySelectorAll<HTMLElement>('.acred-card').forEach(panel => {
      panel.hidden = panel.id !== `panel-${tabId}`;
    });
  }

  // Activar tab según el hash de la URL al cargar
  const hash = window.location.hash.replace('#tab-', '');
  if (hash === 'ema' || hash === 'pjla') {
    activateTab(hash);
    document.getElementById(`tab-${hash}`)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      activateTab(target);
      history.replaceState(null, '', `#tab-${target}`);
    });
  });
</script>
