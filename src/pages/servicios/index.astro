---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { Image } from 'astro:assets';
import slide1 from '../../assets/images/hero/slide-1.png';
import slide2 from '../../assets/images/hero/slide-2.png';
import slide3 from '../../assets/images/hero/slide-3.png';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

// 32 Magnitudes con íconos SVG específicos para cada una.
// Estilo: outline stroke-width 1.75, viewBox 24, currentColor.
const magnitudes = [
  { name: 'Eléctrica',                 svg: '<path d="M13 2 L4 14 h7 l-1 8 10-14 h-7 l1-6 z"/>' },
  { name: 'Presión',                   svg: '<path d="M3 17a9 9 0 1 1 18 0"/><path d="M12 17l5-4"/><circle cx="12" cy="17" r="1.3"/><path d="M6 17h1M17 17h1M12 11v1"/>' },
  { name: 'Temperatura termodinámica', svg: '<path d="M10 4a2 2 0 1 1 4 0v10.5a4 4 0 1 1-4 0V4z"/><path d="M12 8v8"/><circle cx="12" cy="18" r="1.4" fill="currentColor"/>' },
  { name: '%H.R.',                     svg: '<path d="M12 3C8 9 6 13 6 16a6 6 0 0 0 12 0c0-3-2-7-6-13z"/><circle cx="10.5" cy="14.5" r="1"/><circle cx="14" cy="18" r="1"/><path d="M15 13.5l-5 5.5"/>' },
  { name: 'Óptica',                    svg: '<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>' },
  { name: 'Turbidez',                  svg: '<path d="M7 3h10l-1 17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2L7 3z"/><path d="M7.5 9h9"/><circle cx="10" cy="13" r=".8"/><circle cx="14" cy="16" r=".8"/><circle cx="12" cy="11" r=".6"/><circle cx="13" cy="19" r=".5"/>' },
  { name: 'Tiempo',                    svg: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2.5"/>' },
  { name: 'Acústica',                  svg: '<path d="M3 9v6h4l5 4V5L7 9H3z"/><path d="M16 9a4 4 0 0 1 0 6"/><path d="M19 6a8 8 0 0 1 0 12"/>' },
  { name: 'Masa',                      svg: '<path d="M12 4v17"/><path d="M6 21h12"/><path d="M6 8h12"/><circle cx="12" cy="5.5" r="1.2"/><path d="M6 8l-3 6a3 3 0 0 0 6 0L6 8z"/><path d="M18 8l-3 6a3 3 0 0 0 6 0l-3-6z"/>' },
  { name: 'Fuerza',                    svg: '<rect x="13" y="6" width="8" height="12" rx="1"/><path d="M2 12h10"/><path d="M8 8l4 4-4 4"/>' },
  { name: 'Tensión',                   svg: '<path d="M3 4v16M21 4v16"/><path d="M3 12l3-3 2 6 2-6 2 6 2-6 2 6 2-6 3 3"/>' },
  { name: 'Velocidad del aire',        svg: '<path d="M3 8h11a2 2 0 1 0-2-2"/><path d="M3 14h16a2 2 0 1 1-2 2"/><path d="M3 20h8a1.5 1.5 0 1 0-1.5-1.5"/>' },
  { name: 'Velocidad Lineal',          svg: '<path d="M3 16a9 9 0 1 1 18 0"/><path d="M12 16l5-5"/><circle cx="12" cy="16" r="1.4"/><path d="M6 16h1M17 16h1"/>' },
  { name: 'Tensión Superficial',       svg: '<path d="M12 4C9 8 7 11 7 14a5 5 0 0 0 10 0c0-3-2-6-5-10z"/><path d="M3 20h18"/><path d="M5 20l-1 2M9 20l-1 2M13 20l-1 2M17 20l-1 2M21 20l-1 2"/>' },
  { name: 'Torque',                    svg: '<circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5.3 5.3l2.1 2.1M16.6 16.6l2.1 2.1M5.3 18.7l2.1-2.1M16.6 7.4l2.1-2.1"/>' },
  { name: 'Dureza',                    svg: '<path d="M6 3h12l3 5-9 13-9-13z"/><path d="M3 8h18"/><path d="M9 3l3 5 3-5"/><path d="M9 8l3 13M15 8l-3 13"/>' },
  { name: 'Volumen',                   svg: '<path d="M12 3l9 5v8l-9 5-9-5V8z"/><path d="M12 13l9-5M12 13L3 8M12 13v8"/>' },
  { name: 'Densidad',                  svg: '<rect x="4" y="4" width="16" height="16" rx="1"/><circle cx="9" cy="9" r="1" fill="currentColor"/><circle cx="15" cy="9" r="1" fill="currentColor"/><circle cx="9" cy="15" r="1" fill="currentColor"/><circle cx="15" cy="15" r="1" fill="currentColor"/><circle cx="12" cy="12" r="1" fill="currentColor"/>' },
  { name: 'Concentración de Alcohol',  svg: '<path d="M9 3h6"/><path d="M10 3v5L5 19a2 2 0 0 0 2 3h10a2 2 0 0 0 2-3L14 8V3"/><circle cx="10" cy="16" r=".8"/><circle cx="14" cy="14" r=".6"/><circle cx="12" cy="19" r=".6"/>' },
  { name: 'Vibración',                 svg: '<rect x="7" y="9" width="10" height="6" rx="1"/><path d="M3 8l1-1M3 12h2M3 17l1 1"/><path d="M21 8l-1-1M21 12h-2M21 17l-1 1"/>' },
  { name: 'Flujo',                     svg: '<path d="M3 8h18M3 16h18"/><path d="M7 12h10"/><path d="M14 9l3 3-3 3"/>' },
  { name: 'Viscosidad',                svg: '<path d="M7 3h10"/><path d="M8 3c0 4-3 6-3 9a7 7 0 0 0 14 0c0-3-3-5-3-9"/><path d="M12 13v6"/><circle cx="12" cy="20" r="1" fill="currentColor"/>' },
  { name: 'pH',                        svg: '<path d="M9 3v12a3 3 0 0 0 6 0V3"/><path d="M7.5 3h9"/><path d="M9 9h6"/><circle cx="11" cy="13" r=".6" fill="currentColor"/><circle cx="13" cy="11" r=".6" fill="currentColor"/>' },
  { name: 'Conductividad',             svg: '<path d="M9 3v4M15 3v4"/><path d="M7 7h10v4a5 5 0 0 1-5 5v5"/>' },
  { name: 'Cloro',                     svg: '<circle cx="12" cy="12" r="2.2"/><ellipse cx="12" cy="12" rx="10" ry="4"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/>' },
  { name: 'Oxígeno Disuelto',          svg: '<path d="M3 21h18"/><circle cx="8" cy="17" r="2"/><circle cx="14" cy="13" r="1.5"/><circle cx="10" cy="8" r="1"/><circle cx="16" cy="5" r=".7"/>' },
  { name: 'Dimensional',               svg: '<rect x="2" y="9" width="20" height="6" rx="1"/><path d="M6 9v3M10 9v3M14 9v3M18 9v3M4 9v2M8 9v2M12 9v2M16 9v2M20 9v2"/>' },
  { name: 'Mediciones especiales',     svg: '<path d="M12 3v4M12 17v4M3 12h4M17 12h4"/><path d="M6 6l2.5 2.5M15.5 15.5L18 18M6 18l2.5-2.5M15.5 8.5L18 6"/><circle cx="12" cy="12" r="3"/>' },
  { name: '%Humedad',                  svg: '<path d="M7 15a4 4 0 0 1 0-8 5 5 0 0 1 10 0 3 3 0 0 1 0 6"/><path d="M12 15c-1.3 2.2-2 3.3-2 4.3a2 2 0 0 0 4 0c0-1-.7-2.1-2-4.3z"/>' },
  { name: 'Frecuencia',                svg: '<path d="M2 12c2-6 4-6 6 0s4 6 6 0 4-6 6 0"/><path d="M3 20v1M21 20v1M12 20v1"/>' },
  { name: 'Coeficiente de Fricción',   svg: '<rect x="5" y="7" width="12" height="6" rx="1"/><path d="M3 15h18"/><path d="M6 18l-1 2M10 18l-1 2M14 18l-1 2M18 18l-1 2"/><path d="M17 10h5M20 8l2 2-2 2"/>' },
  { name: 'Ondas de Radio',            svg: '<path d="M8 21l4-15 4 15"/><path d="M10 15h4"/><path d="M5 10a10 10 0 0 1 14 0"/><path d="M3 7a14 14 0 0 1 18 0"/>' },
];
---

<Base
  title="Servicios de Calibración Acreditada — IME Calibraciones | Tlaxcala, México"
  description="Calibración acreditada EMA bajo ISO/IEC 17025. 32 magnitudes: temperatura, presión, masa, dimensional, eléctrico y más. Servicio en laboratorio y en campo. Tlaxcala, México."
>
  <script type="application/ld+json" slot="head">{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Servicios de Calibración IME Calibraciones",
    "provider": {
      "@type": "Organization",
      "@id": "https://imecalibraciones.com/#organization",
      "name": "IME Calibraciones",
      "url": "https://imecalibraciones.com"
    },
    "areaServed": { "@type": "Country", "name": "México" },
    "serviceType": "Calibración metrológica acreditada ISO/IEC 17025",
    "description": "Calibración acreditada bajo ISO/IEC 17025 para 32 magnitudes físicas. Trazabilidad CENAM/NIST. Servicio en laboratorio y en campo en toda la República Mexicana."
  }</script>

  <main>

    <!-- ══ SECCIÓN 1: PAGE HEADER COMPACTO ══ -->
    <PageHeader
      label="Servicio de calibración y venta de suministros IME"
      breadcrumb={[{ label: 'Inicio', href: `${b}/` }, { label: 'Servicios' }]}
      title="Servicio de Calibración"
      titleAccent="& Venta de Suministros"
      subtitle="Modalidades de servicio, 32 magnitudes y el respaldo técnico detrás de cada certificado."
      anchors={[
        { label: 'Modalidades',      href: '#modalidades' },
        { label: 'Magnitudes',       href: '#magnitudes'  },
        { label: 'Respaldo Técnico', href: '#respaldo'   },
      ]}
      video={`${b}/assets/video/hero-servicios.mp4`}
      poster={`${b}/assets/images/hero/hero-poster.png`}
      mediaFit="contain"
    />

    <!-- ══ SECCIÓN 2: MODALIDADES ══ -->
    <section id="modalidades" class="section srv-modalidades" aria-labelledby="modalidades-heading">
      <div class="container">

        <header class="section__header text-center">
          <p class="section__eyebrow">Cómo trabajamos</p>
          <h2 class="section-title" id="modalidades-heading">Dos modalidades de servicio</h2>
          <p class="section__subtitle text-muted">Adaptamos el servicio para minimizar tiempos de paro.</p>
        </header>

        <div class="srv-modalidades__grid">

          <!-- Card: En el Laboratorio -->
          <article class="srv-modalidad animate-on-scroll">
            <div class="srv-modalidad__img-wrap">
              <Image
                src={slide1}
                alt="Interior del laboratorio IME — instalaciones especializadas de calibración"
                widths={[480,800,1200]}
                sizes="(max-width:768px) 100vw, 50vw"
                loading="lazy"
                format="webp"
                quality={75}
              />
              <div class="srv-modalidad__img-overlay" aria-hidden="true"></div>
              <div class="srv-modalidad__tag srv-modalidad__tag--blue">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 2.25a.75.75 0 000 1.5v16.5h-.75a.75.75 0 000 1.5H15v-18a.75.75 0 000-1.5H3zM6.75 19.5v-2.25a.75.75 0 01.75-.75h3a.75.75 0 01.75.75v2.25a.75.75 0 01-.75.75h-3a.75.75 0 01-.75-.75zM6 6.75A.75.75 0 016.75 6h.75a.75.75 0 010 1.5h-.75A.75.75 0 016 6.75zM6.75 9h.75a.75.75 0 010 1.5h-.75a.75.75 0 010-1.5zM6 12.75a.75.75 0 01.75-.75h.75a.75.75 0 010 1.5h-.75a.75.75 0 01-.75-.75zM10.5 6a.75.75 0 000 1.5h.75a.75.75 0 000-1.5h-.75zm-.75 3.75A.75.75 0 0110.5 9h.75a.75.75 0 010 1.5h-.75a.75.75 0 01-.75-.75zM10.5 12a.75.75 0 000 1.5h.75a.75.75 0 000-1.5h-.75z" clip-rule="evenodd"/>
                </svg>
                En el Laboratorio
              </div>
            </div>
            <div class="srv-modalidad__body">
              <h3 class="srv-modalidad__title">Calibración en Nuestras Instalaciones</h3>
              <p class="srv-modalidad__intro">
                La opción ideal para un entorno controlado y personal especializado.
              </p>
              <ul class="srv-modalidad__list" role="list">
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  <div>
                    <strong>1,814 m² de instalaciones</strong>
                    <span>Laboratorios especializados con espacios controlados para cada calibración</span>
                  </div>
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  <div>
                    <strong>Asesores especializados</strong>
                    <span>Seguimiento a tu servicio en cada etapa de la calibración</span>
                  </div>
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  <div>
                    <strong>Condiciones controladas</strong>
                    <span>Entorno diseñado para obtener resultados más exactos</span>
                  </div>
                </li>
              </ul>
              <a href={`${b}/contacto/`} class="btn btn-primary">Solicitar servicio en laboratorio</a>
            </div>
          </article>

          <!-- Card: En Sitio -->
          <article class="srv-modalidad animate-on-scroll">
            <div class="srv-modalidad__img-wrap">
              <Image
                src={slide3}
                alt="Técnico IME calibrando equipo directamente en instalaciones del cliente"
                widths={[480,800,1200]}
                sizes="(max-width:768px) 100vw, 50vw"
                loading="lazy"
                format="webp"
                quality={75}
              />
              <div class="srv-modalidad__img-overlay" aria-hidden="true"></div>
              <div class="srv-modalidad__tag srv-modalidad__tag--gold">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M3.375 4.5C2.339 4.5 1.5 5.34 1.5 6.375V13.5h12V6.375c0-1.036-.84-1.875-1.875-1.875h-8.25zM13.5 15h-12v2.625c0 1.035.84 1.875 1.875 1.875h.375a3 3 0 116 0h3a.75.75 0 00.75-.75V15z"/>
                  <path d="M8.25 19.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0zM15.75 6.75a.75.75 0 00-.75.75v11.25c0 .087.015.17.042.248a3 3 0 015.958.464c.853-.175 1.522-.935 1.464-1.883a18.659 18.659 0 00-3.732-10.104 1.837 1.837 0 00-1.47-.725H15.75z"/>
                  <path d="M19.5 19.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0z"/>
                </svg>
                Calibración en Sitio
              </div>
            </div>
            <div class="srv-modalidad__body">
              <h3 class="srv-modalidad__title">Calibración en sus Instalaciones</h3>
              <p class="srv-modalidad__intro">
                Ideal cuando necesitas continuidad operativa, rapidez y trabajar directamente en condiciones reales.
              </p>
              <ul class="srv-modalidad__list" role="list">
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  <div>
                    <strong>Evaluación en condiciones reales</strong>
                    <span>El equipo se evalúa en el entorno donde realmente opera, considerando variables reales del proceso</span>
                  </div>
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  <div>
                    <strong>Equipos difíciles de mover</strong>
                    <span>Ideal para instrumentos sensibles, pesados o instalados directamente en línea</span>
                  </div>
                </li>
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
                  <div>
                    <strong>Protocolos de seguridad industrial</strong>
                    <span>Personal certificado operando bajo normativas y estándares vigentes</span>
                  </div>
                </li>
              </ul>
              <a href={`${b}/contacto/`} class="btn btn-secondary">Solicitar servicio en sitio</a>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ══ SECCIÓN 3: 32 MAGNITUDES ══ -->
    <section class="srv-mag section" id="magnitudes" aria-labelledby="mag-heading">
      <div class="container">

        <!-- Header -->
        <header class="section__header text-center">
          <p class="section__eyebrow" id="mag-heading">Nuestras capacidades</p>
          <h2 class="section-title">32 Magnitudes de Calibración</h2>
          <p class="section__subtitle text-muted">
            Un solo proveedor para todas tus necesidades de calibración. Si no encuentras tu instrumento, contáctanos.
          </p>
        </header>

        <!-- Grid con íconos — cascada diagonal al entrar al viewport -->
        <ol class="srv-mag__grid animate-on-scroll" aria-label="Lista de magnitudes calibradas">
          {magnitudes.map((m, i) => (
            <li class="srv-mag__card" style={`--i:${i}`}>
              <div class="srv-mag__inner">
                <div class="srv-mag__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={m.svg} />
                </div>
                <span class="srv-mag__name">{m.name}</span>
              </div>
            </li>
          ))}
        </ol>

        <div class="srv-mag__cta-wrap">
          <a href={`${b}/catalogo/`} class="srv-mag__cta">
            <span>Ver catálogo completo de instrumentos</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 10h12M11 5l5 5-5 5"/>
            </svg>
          </a>
        </div>

      </div>
    </section>

    <!-- ══ SECCIÓN 4: RESPALDO TÉCNICO ══ -->
    <section id="respaldo" class="section section--alt srv-respaldo" aria-labelledby="respaldo-heading">
      <div class="container">

        <header class="section__header text-center">
          <p class="section__eyebrow">Confianza y trazabilidad</p>
          <h2 class="section-title" id="respaldo-heading">Respaldo Técnico Internacional</h2>
          <p class="section__subtitle text-muted">
            Nuestros Certificados son reconocidos por organismos acreditadores Nacionales e Internacionales.
          </p>
        </header>

        <ul class="srv-respaldo__list" role="list">

          <li class="srv-respaldo__item animate-on-scroll">
            <div class="srv-respaldo__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/>
                <path d="M3 12h18"/>
                <path d="M12 3c2.5 2.5 4 5.5 4 9s-1.5 6.5-4 9"/>
                <path d="M12 3c-2.5 2.5-4 5.5-4 9s1.5 6.5 4 9"/>
              </svg>
            </div>
            <h3 class="srv-respaldo__title">ILAC/MRA</h3>
            <p class="srv-respaldo__body">Acuerdo internacional que garantiza la aceptación global de nuestros certificados.</p>
          </li>

          <li class="srv-respaldo__item animate-on-scroll">
            <div class="srv-respaldo__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="9" r="6"/>
                <path d="M8 14l-2 7 6-3 6 3-2-7"/>
                <path d="M9.5 9l2 2 3.5-3.5"/>
              </svg>
            </div>
            <h3 class="srv-respaldo__title">ISO/IEC 17025</h3>
            <p class="srv-respaldo__body">Norma internacional que certifica la competencia técnica del laboratorio.</p>
          </li>

          <li class="srv-respaldo__item animate-on-scroll">
            <div class="srv-respaldo__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <h3 class="srv-respaldo__title">EMA</h3>
            <p class="srv-respaldo__body">Entidad Mexicana de Acreditación que avala nuestra competencia nacional.</p>
          </li>

          <li class="srv-respaldo__item animate-on-scroll">
