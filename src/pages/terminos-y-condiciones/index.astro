---
import Base from '../../layouts/Base.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Términos y Condiciones — IME Calibraciones"
  description="Términos y condiciones de uso del sitio web de IME Calibraciones."
>
  <main>

    <!-- ===== PAGE HERO ===== -->
    <section class="page-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Ruta de navegación">
          <ol>
            <li><a href={`${b}/`}>Inicio</a></li>
            <li aria-current="page">Términos y Condiciones</li>
          </ol>
        </nav>
        <h1>Términos y Condiciones</h1>
        <p class="page-hero__subtitle">
          Condiciones de uso del sitio web de IME Calibraciones.
        </p>
      </div>
    </section>

    <!-- ===== CONTENIDO ===== -->
    <!-- TODO: migrar el texto completo de términos y condiciones del sitio actual.
         Verificar con asesor legal que el contenido sea vigente y aplicable.
         Indicar la fecha de última actualización. -->
    <section class="section">
      <div class="container container--narrow">
        <div class="legal-content">

          <p class="legal-content__updated">
            <em>Última actualización: <!-- TODO: fecha de última revisión --> (pendiente)</em>
          </p>

          <h2>1. Aceptación de los Términos</h2>
          <!-- TODO: texto definitivo — migrar del sitio actual -->
